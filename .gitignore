# Large generated directories — go to GitHub Release, not the git repo
prefix/
wineprefix/
rootfs/

# Keep the scripts that manage these dirs
!bin/
!bin/**

# appimagetool is downloaded by pack-appimage.sh — don't commit
bin/appimagetool
bin/squashfs-root/

# AppDir is a temporary build artifact from pack-appimage.sh
AppDir/

# host-debs/ MUST be committed (pre-downloaded .deb packages for offline install)
# Do NOT add a *.deb pattern here — it would exclude host-debs/

# Build artifacts
_build/
*.tar.zst
*.tar.gz
*.zip

# AppImage output (generated by pack-appimage.sh, uploaded to Releases)
*.AppImage

# Logs
*.log

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# OS
.DS_Store
Thumbs.db

# Editor
*.swp
*.swo
*~
.idea/
.vscode/
