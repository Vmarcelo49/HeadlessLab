#!/usr/bin/env python3
# headless — Unified CLI tool for AI agents to control Windows GUI apps under Wine + Xvfb + bwrap.
import os
import sys
import json
import time
import subprocess
import argparse
import hashlib
import shutil
from datetime import datetime, timezone

# --- Registry & Cache Paths ---
CACHE_DIR = os.path.expanduser("~/.cache/headlesslab")
REGISTRY_PATH = os.path.join(CACHE_DIR, "registry.json")
DEBUG_LOG_PATH = os.path.join(CACHE_DIR, "debug.log")
WINEPREFIX_TEMPLATE = os.path.join(CACHE_DIR, "wineprefix_template")

def iso_now():
    return datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")

def debug_log(msg):
    """Append a debug line to the rotating debug log (capped at 1MB)."""
    try:
        os.makedirs(os.path.dirname(DEBUG_LOG_PATH), exist_ok=True)
        # Rotate if too big
        if os.path.exists(DEBUG_LOG_PATH) and os.path.getsize(DEBUG_LOG_PATH) > 1024 * 1024:
            shutil.move(DEBUG_LOG_PATH, DEBUG_LOG_PATH + ".old")
        with open(DEBUG_LOG_PATH, "a") as f:
            f.write(f"[{iso_now()}] {msg}\n")
    except Exception:
        pass

class SessionRegistry:
    @staticmethod
    def _load():
        if not os.path.exists(REGISTRY_PATH):
            return {"sessions": {}}
        try:
            with open(REGISTRY_PATH, "r") as f:
                return json.load(f)
        except Exception:
            return {"sessions": {}}

    @staticmethod
    def _save(data):
        os.makedirs(os.path.dirname(REGISTRY_PATH), exist_ok=True)
        with open(REGISTRY_PATH, "w") as f:
            json.dump(data, f, indent=2)

    @classmethod
    def register(cls, session_id, pid, display, wineprefix, log_path):
        data = cls._load()
        data["sessions"][session_id] = {
            "pid": pid,
            "display": display,
            "wineprefix": wineprefix,
            "log_path": log_path,
            "created_at": iso_now(),
            "state": "running"
        }
        cls._save(data)

    @classmethod
    def get(cls, session_id):
        data = cls._load()
        return data["sessions"].get(session_id)

    @classmethod
    def list_all(cls):
        data = cls._load()
        return data["sessions"]

    @classmethod
    def unregister(cls, session_id):
        data = cls._load()
        if session_id in data["sessions"]:
            del data["sessions"][session_id]
            cls._save(data)


# --- Helper Functions ---

def print_json(data):
    print(json.dumps(data), flush=True)

def print_error(code, message, exit_code=1):
    print_json({"status": "error", "code": code, "message": message})
    sys.exit(exit_code)

def get_appdir():
    # If running inside AppImage, APPDIR is defined by the runtime
    return os.environ.get("APPDIR", os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

def get_prefix_dir():
    if "APPDIR" in os.environ:
        return os.environ["APPDIR"]
    else:
        return os.path.join(get_appdir(), "prefix")


def detect_pe_arch(exe_path):
    """Detect the architecture of a Windows PE binary by reading the COFF
    'Machine' field at offset 0x3C+4. Returns 'i386', 'x86_64', or 'unknown'.
    Used to decide whether to use wine64 (for x86_64 PE) or wine (for i386 PE
    via WoW64). For Windows-style paths (C:\\...) we can't read the file
    directly, so we return 'unknown' and let Wine auto-detect."""
    try:
        with open(exe_path, "rb") as f:
            # MZ header: first 2 bytes should be b"MZ"
            if f.read(2) != b"MZ":
                return "unknown"
            # e_lfanew at offset 0x3C points to PE header
            f.seek(0x3C)
            pe_offset = int.from_bytes(f.read(4), "little")
            f.seek(pe_offset)
            # PE signature: "PE\0\0"
            if f.read(4) != b"PE\x00\x00":
                return "unknown"
            # Next 2 bytes: Machine field
            machine = int.from_bytes(f.read(2), "little")
            if machine == 0x14C:    # IMAGE_FILE_MACHINE_I386
                return "i386"
            elif machine == 0x8664: # IMAGE_FILE_MACHINE_AMD64
                return "x86_64"
            elif machine == 0xAA64: # IMAGE_FILE_MACHINE_ARM64
                return "arm64"
            elif machine == 0x1C0:  # IMAGE_FILE_MACHINE_ARM
                return "arm"
            else:
                return f"unknown(0x{machine:04x})"
    except Exception:
        return "unknown"


def mirror_clsids_to_wow64(wineprefix_template, wine_dir):
    """Mirror ALL COM CLSIDs from the 64-bit registry view to the 32-bit
    (Wow6432Node) view, and create missing DLL symlinks in syswow64/.

    Wine 11's PE-only WoW64 doesn't automatically reflect CLSID registry
    entries between 32-bit and 64-bit views. Many 32-bit Windows games use
    KEY_WOW64_32KEY when calling CoCreateInstance, which looks in
    HKLM\\Software\\Classes\\Wow6432Node\\CLSID\\... If the CLSID is only in
    the 64-bit view, CoCreateInstance returns REGDB_E_CLASSNOTREG and the
    game crashes (many games don't check the return value).

    This function reads system.reg, finds all CLSID InprocServer32 entries,
    and adds Wow6432Node copies with system32 paths converted to syswow64.
    Also creates missing DLL symlinks in syswow64/ subdirectories (wbem/,
    ADO/, OLE DB/, etc.) so the 32-bit DLLs can be loaded.

    This replicates what Wine's old WoW64 (with unix libs) did automatically
    via registry reflection, and what winetricks achieves by running
    regsvr32 on each DirectX DLL.
    """
    import re as _re
    system_reg = os.path.join(wineprefix_template, "system.reg")
    if not os.path.exists(system_reg):
        return

    with open(system_reg, "r", errors="replace") as f:
        content = f.read()

    syswow64 = os.path.join(wineprefix_template, "drive_c", "windows", "syswow64")
    i386_src = os.path.join(wine_dir, "lib", "wine", "i386-windows")

    # Find all CLSID InprocServer32 entries (64-bit view)
    inproc_pattern = _re.compile(
        r'\[Software\\\\Classes\\\\CLSID\\\\(\{[0-9A-Fa-f-]+\})\\\\InprocServer32\][^\n]*\n'
        r'(?:#[^\n]*\n)*'
        r'@="([^"]*)"\n'
        r'(?:#[^\n]*\n)*'
        r'"ThreadingModel"="([^"]*)"'
    )
    name_pattern = _re.compile(
        r'\[Software\\\\Classes\\\\CLSID\\\\(\{[0-9A-Fa-f-]+\})\][^\n]*\n'
        r'(?:#[^\n]*\n)*'
        r'@="([^"]*)"'
    )
    names = dict(name_pattern.findall(content))
    inprocs = inproc_pattern.findall(content)

    to_add = []
    for guid, dll_path, threading in inprocs:
        if f"Wow6432Node\\\\CLSID\\\\{guid}" in content:
            continue
        dll_32 = dll_path.replace("system32", "syswow64")
        name = names.get(guid, "Unknown")
        to_add.append((guid, name, dll_32, threading))

    if not to_add:
        return

    # Create missing DLL symlinks in syswow64/ subdirectories
    for guid, name, dll_32, threading in to_add:
        parts = dll_32.replace("\\\\", "\\").split("\\")
        filename = parts[-1]
        subdir = ""
        if len(parts) > 2 and parts[-2] not in ["syswow64", "system32"]:
            subdir = parts[-2]
        if subdir:
            dll_file = os.path.join(syswow64, subdir, filename)
        else:
            dll_file = os.path.join(syswow64, filename)
        if not os.path.lexists(dll_file):
            wine_dll = os.path.join(i386_src, filename)
            if os.path.exists(wine_dll):
                target_dir = os.path.dirname(dll_file)
                os.makedirs(target_dir, exist_ok=True)
                try:
                    os.symlink(wine_dll, dll_file)
                except Exception:
                    pass

    # Append Wow6432Node entries to system.reg
    timestamp = int(time.time())
    entries = []
    for guid, name, dll_32, threading in to_add:
        entries.append(
            f"\n[Software\\\\Classes\\\\Wow6432Node\\\\CLSID\\\\{guid}] {timestamp}\n"
            f"#time=1dd09060dd935e6\n"
            f'@="{name}"\n'
            f"\n[Software\\\\Classes\\\\Wow6432Node\\\\CLSID\\\\{guid}\\\\InprocServer32] {timestamp}\n"
            f"#time=1dd09060dd935e6\n"
            f'@="{dll_32}"\n'
            f'"ThreadingModel"="{threading}"\n'
        )
    new_content = content + "".join(entries)
    with open(system_reg, "w") as f:
        f.write(new_content)
    debug_log(f"Mirrored {len(to_add)} CLSIDs to Wow6432Node in {system_reg}")


def detect_pe_subsystem(exe_path):
    """Detect the PE subsystem of a Windows binary.
    Returns 2 (GUI), 3 (Console), or 0 (unknown).
    Used to decide whether to use 'wine' (GUI) or 'wineconsole' (console)."""
    try:
        with open(exe_path, "rb") as f:
            if f.read(2) != b"MZ":
                return 0
            f.seek(0x3C)
            pe_offset = int.from_bytes(f.read(4), "little")
            f.seek(pe_offset)
            # PE signature: 0x50 0x45 0x00 0x00
            sig = f.read(4)
            if sig != b"PE" + b"\x00" + b"\x00":
                return 0
            # Skip COFF header (20 bytes) + Magic (2 bytes)
            f.seek(pe_offset + 4 + 20)
            magic = int.from_bytes(f.read(2), "little")
            if magic == 0x10B or magic == 0x20B:  # PE32 or PE32+
                # Subsystem is at offset 68 in Optional Header
                f.seek(pe_offset + 4 + 20 + 68)
            else:
                return 0
            return int.from_bytes(f.read(2), "little")
    except Exception:
        return 0


def get_wine_binary():
    """Return the Wine binary path INSIDE the bwrap sandbox.
    Wine 11 from WineHQ installs to /opt/wine-devel/ with hardcoded paths.
    The single 'wine' binary handles both 32-bit and 64-bit PE via WoW64."""
    return "/opt/wine-devel/bin/wine"


# --- Process liveness & crash detection helpers (shared by cmd_exec and cmd_wait_window) ---
#
# These helpers were originally inlined in cmd_exec for BUG-001. They are
# now module-level so cmd_wait_window (BUG-002) can reuse them to detect
# process death while polling for windows.

# Process name substrings that indicate a Wine helper, not the user's EXE.
# When only these are alive, the EXE itself has crashed.
WINE_HELPER_MARKERS = ("winedbg", "wineboot", "winedevice", "wineserver",
                       "services.exe", "plugplay.exe", "explorer.exe",
                       "rpcss.exe", "svchost.exe", "winemenubuilder.exe",
                       "start.exe", "conhost.exe")

# Crash markers we look for in the Wine log. All matched case-insensitively.
WINE_CRASH_MARKERS = (
    "unhandled page fault",
    "access violation",
    "unhandled exception",
    "wine: Unhandled",
)


def live_user_pids(prefix_pids):
    """Filter prefix PIDs to only those that look like the user's EXE
    (not Wine helper processes). Returns the filtered list.

    Used by cmd_exec and cmd_wait_window to distinguish "EXE is alive"
    from "only Wine helpers are alive (EXE has crashed)".
    """
    live = []
    for p in prefix_pids:
        try:
            with open(f"/proc/{p}/cmdline", "rb") as f:
                cmdline = f.read().replace(b"\x00", b" ").decode("utf-8", errors="ignore").lower()
        except Exception:
            continue
        # Skip Wine helper processes
        if any(marker in cmdline for marker in WINE_HELPER_MARKERS):
            continue
        # Skip the bwrap wrapper itself
        if "bwrap" in cmdline:
            continue
        live.append(p)
    return live


def log_shows_crash(path, file_handle=None):
    """Check the Wine log for strong crash signals.

    Reads only the last 8KB of the log to stay fast. If `file_handle` is
    provided (the open log file from cmd_exec), it is flushed+fsync'd
    first so buffered data is visible on disk.
    """
    if file_handle is not None:
        try:
            file_handle.flush()
            os.fsync(file_handle.fileno())
        except Exception:
            pass
    try:
        with open(path, "r", errors="ignore") as f:
            f.seek(0, 2)
            size = f.tell()
            f.seek(max(0, size - 8192))
            tail = f.read()
        for marker in WINE_CRASH_MARKERS:
            if marker.lower() in tail.lower():
                return marker
    except Exception:
        pass
    return None


def get_wine_dir():
    """Return the host path to the Wine installation directory."""
    return os.path.join(get_prefix_dir(), "opt", "wine-devel")

def find_free_display():
    for i in range(99, 200):
        lock_file = f"/tmp/.X{i}-lock"
        unix_socket = f"/tmp/.X11-unix/X{i}"
        if not os.path.exists(lock_file) and not os.path.exists(unix_socket):
            return f":{i}"
    raise RuntimeError("No free displays found")

def get_pids_for_prefix(wineprefix):
    pids = []
    for pid_str in os.listdir("/proc"):
        if not pid_str.isdigit():
            continue
        try:
            with open(f"/proc/{pid_str}/environ", "rb") as f:
                environ_bytes = f.read()
            env = {}
            for item in environ_bytes.split(b"\x00"):
                if b"=" in item:
                    parts = item.split(b"=", 1)
                    env[parts[0].decode("utf-8", errors="ignore")] = parts[1].decode("utf-8", errors="ignore")
            if env.get("WINEPREFIX") == wineprefix:
                pids.append(int(pid_str))
        except Exception:
            continue
    return pids

def get_windows_for_session(display, session_pids, exe_basename=None, session_created_at=None):
    """List X11 windows belonging to a session.

    Primary filter: window's _NET_WM_PID is in session_pids.
    Fallback (BUG-007 fix): if no windows match by PID, also include windows
    whose WM_CLASS matches exe_basename (e.g. "mbaa.exe"), or windows that
    appeared after the session was created. This catches modal dialogs
    (MessageBox, Error dialogs) whose _NET_WM_PID doesn't match the
    wineprefix's PIDs.
    """
    env = os.environ.copy()
    env["DISPLAY"] = display
    try:
        res = subprocess.run(["wmctrl", "-l", "-p"], env=env, capture_output=True, text=True)
        debug_log(f"get_windows_for_session: session_pids={session_pids}")
        debug_log(f"get_windows_for_session: wmctrl output:\n{res.stdout}")
        if res.returncode != 0:
            return []

        # Parse all windows from wmctrl output
        all_windows = []
        for line in res.stdout.splitlines():
            parts = line.split(None, 4)
            if len(parts) >= 4:
                w_id = parts[0]
                # parts[2] is the PID (wmctrl -p format: id desktop pid title)
                try:
                    pid = int(parts[2])
                except (ValueError, IndexError):
                    pid = 0
                title = parts[4] if len(parts) > 4 else ""
                all_windows.append({"id": w_id, "pid": pid, "title": title})

        # Primary filter: PID match
        windows = [w for w in all_windows if w["pid"] in session_pids]
        if windows:
            return windows

        # Fallback 1 (BUG-007): No windows matched by PID. This commonly
        # happens with modal dialogs (MessageBox, Error dialogs) whose
        # _NET_WM_PID doesn't match the wineprefix's process tree. Try
        # matching by WM_CLASS against the EXE basename.
        if exe_basename:
            exe_lower = exe_basename.lower().replace(".exe", "")
            for w in all_windows:
                if w["pid"] and w["pid"] in session_pids:
                    continue  # already checked
                # Get WM_CLASS via xprop
                try:
                    xprop_res = subprocess.run(
                        ["xprop", "-id", w["id"], "WM_CLASS"],
                        env=env, capture_output=True, text=True, timeout=2
                    )
                    if xprop_res.returncode == 0:
                        wm_class = xprop_res.stdout.lower()
                        # WM_CLASS looks like: WM_CLASS(STRING) = "mbaa.exe", "mbaa.exe"
                        if exe_lower in wm_class:
                            w["matched_by"] = "wm_class"
                            windows.append(w)
                            continue
                except Exception:
                    pass

        if windows:
            return windows

        # Fallback 2: If we still have no windows but there ARE windows on
        # the display, and the session was created recently, include any
        # window whose title looks like an error/dialog. This is a last
        # resort to catch Wine's built-in dialogs ("Error", "Wine Mono
        # Installer", "Program Error", "Wine Debugger").
        if not windows and all_windows:
            DIALOG_TITLES = (
                "error", "wine", "program error", "wine debugger",
                "wine mono installer", "unhandled", "exception",
            )
            for w in all_windows:
                if w["pid"] and w["pid"] in session_pids:
                    continue  # already checked
                title_lower = w["title"].lower()
                if any(dt in title_lower for dt in DIALOG_TITLES):
                    w["matched_by"] = "dialog_title"
                    windows.append(w)

        return windows
    except Exception as e:
        debug_log(f"get_windows_for_session exception: {e}")
        return []


def rebuild_rootfs(rootfs):
    import shutil
    if os.path.exists(rootfs):
        try:
            shutil.rmtree(rootfs)
        except Exception:
            pass
        
    os.makedirs(f"{rootfs}/usr/lib", exist_ok=True)
    os.makedirs(f"{rootfs}/usr/lib/x86_64-linux-gnu", exist_ok=True)
    os.makedirs(f"{rootfs}/usr/share", exist_ok=True)
    os.makedirs(f"{rootfs}/usr/bin", exist_ok=True)
    os.makedirs(f"{rootfs}/usr/sbin", exist_ok=True)
    
    # Symlinks for /usr/lib/* (skipping wine and x86_64-linux-gnu)
    for name in os.listdir("/usr/lib"):
        if name in ["wine", "x86_64-linux-gnu"]:
            continue
        try:
            os.symlink(f"/host-usr/lib/{name}", f"{rootfs}/usr/lib/{name}")
        except Exception:
            pass
        
    # Symlinks for /usr/lib/x86_64-linux-gnu/* (skipping wine)
    for name in os.listdir("/usr/lib/x86_64-linux-gnu"):
        if name == "wine":
            continue
        try:
            os.symlink(f"/host-usr/lib/x86_64-linux-gnu/{name}", f"{rootfs}/usr/lib/x86_64-linux-gnu/{name}")
        except Exception:
            pass
        
    # Symlinks for /usr/share/* (skipping wine and vulkan)
    for name in os.listdir("/usr/share"):
        if name in ["wine", "vulkan"]:
            continue
        try:
            os.symlink(f"/host-usr/share/{name}", f"{rootfs}/usr/share/{name}")
        except Exception:
            pass
        
    # Symlinks for /usr/bin/* and /usr/sbin/*
    for name in os.listdir("/usr/bin"):
        try:
            os.symlink(f"/host-usr/bin/{name}", f"{rootfs}/usr/bin/{name}")
        except Exception:
            pass
    for name in os.listdir("/usr/sbin"):
        try:
            os.symlink(f"/host-usr/sbin/{name}", f"{rootfs}/usr/sbin/{name}")
        except Exception:
            pass
        
    # Base directories of rootfs
    for d in ["bin", "sbin", "lib", "lib64", "etc"]:
        try:
            os.symlink(f"/host-{d}", f"{rootfs}/{d}")
        except Exception:
            pass
        
    # Create empty folders that will be bind-mounted (bwrap populates them)
    os.makedirs(f"{rootfs}/usr/lib/wine", exist_ok=True)
    os.makedirs(f"{rootfs}/usr/lib/x86_64-linux-gnu/wine", exist_ok=True)
    os.makedirs(f"{rootfs}/usr/lib/i386-linux-gnu/wine", exist_ok=True)  # for 32-bit WoW64
    os.makedirs(f"{rootfs}/usr/share/wine", exist_ok=True)
    os.makedirs(f"{rootfs}/usr/share/vulkan", exist_ok=True)


# --- CLI Command Implementations ---

def _start_display(display, geometry):
    """Shared helper: launches Xvfb + Openbox on the given display.
    Sets XDG_DATA_DIRS so Openbox can find its themes (critical when host
    packages are installed in ~/.local/usr instead of /usr).
    Returns (success: bool, error_message: str)."""
    xvfb_log = open("/tmp/xvfb.log", "a")

    # 1. Launch Xvfb
    try:
        subprocess.Popen(
            ["Xvfb", display, "-screen", "0", geometry, "-ac", "-nolisten", "tcp"],
            stdout=subprocess.DEVNULL,
            stderr=xvfb_log,
            preexec_fn=os.setsid
        )
    except FileNotFoundError:
        return False, "Xvfb binary not found on host PATH. Install with: apt-get install xvfb"
    except Exception as e:
        return False, f"Failed to start Xvfb: {e}"

    time.sleep(2)  # wait for startup

    # Verify Xvfb is actually running
    if not os.path.exists(f"/tmp/.X11-unix/X{display.lstrip(':')}"):
        with open("/tmp/xvfb.log", "r", errors="ignore") as f:
            log_tail = f.read()[-500:]
        return False, f"Xvfb did not create socket. Log tail: {log_tail}"

    # 2. Launch Openbox — XDG_DATA_DIRS must include any prefix where themes live
    # (e.g. ~/.local/usr/share when host tools were installed via apt-get download)
    env = os.environ.copy()
    env["DISPLAY"] = display
    xdg = env.get("XDG_DATA_DIRS", "")
    extra_dirs = []
    home_local_share = os.path.expanduser("~/.local/usr/share")
    if os.path.isdir(home_local_share) and home_local_share not in xdg:
        extra_dirs.append(home_local_share)
    for d in ["/usr/share", "/usr/local/share"]:
        if d not in xdg:
            extra_dirs.append(d)
    env["XDG_DATA_DIRS"] = ":".join(extra_dirs + ([xdg] if xdg else []))

    openbox_log = open("/tmp/openbox.log", "a")
    try:
        subprocess.Popen(
            ["openbox", "--sm-disable"],
            env=env,
            stdout=subprocess.DEVNULL,
            stderr=openbox_log,
            preexec_fn=os.setsid
        )
    except FileNotFoundError:
        return False, "openbox binary not found on host PATH. Install with: apt-get install openbox"
    except Exception as e:
        return False, f"Failed to start openbox: {e}"

    time.sleep(1)

    # 3. Pin keyboard layout to us
    subprocess.run(["setxkbmap", "us"], env=env, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    return True, ""


def cmd_init(args):
    try:
        display = find_free_display()
    except Exception as e:
        print_error("NO_FREE_DISPLAY", str(e))

    # Respect --geometry (was previously hardcoded to 1920x1080x24)
    geometry = args.geometry or "1920x1080x24"

    ok, err = _start_display(display, geometry)
    if not ok:
        print_error("INIT_FAILED", err)

    print_json({"status": "ok", "display": display, "geometry": geometry})


def cmd_exec(args):
    appdir = get_appdir()
    session_id = f"sess_{int(time.time())}"
    display = args.display
    
    # If no display provided, find the first RUNNING session's display.
    # Dead sessions may have stale display numbers — skip them.
    if not display:
        sessions = SessionRegistry.list_all()
        for info in sessions.values():
            if os.path.exists(f"/proc/{info['pid']}"):
                display = info["display"]
                break
        if not display:
            # No running sessions — find any active Xvfb display
            for i in range(99, 200):
                if os.path.exists(f"/tmp/.X11-unix/X{i}"):
                    display = f":{i}"
                    break
            if not display:
                display = ":99"

    # Setup per-session writable directories
    session_work = os.path.join(CACHE_DIR, session_id)
    wineprefix = os.path.join(session_work, "wineprefix")
    rootfs = os.path.join(session_work, "rootfs")
    log_path = f"/tmp/wine_debug_{session_id}.log"
    os.makedirs(session_work, exist_ok=True)

    # 1. Rebuild rootfs
    try:
        rebuild_rootfs(rootfs)
    except Exception as e:
        print_error("ROOTFS_FAILED", f"Failed to rebuild rootfs: {e}")

    # 2. Init WINEPREFIX
    prefix_dir = get_prefix_dir()
    wine_dir = get_wine_dir()
    bwrap_base = [
        f"{prefix_dir}/usr/bin/bwrap",
        "--ro-bind", "/usr", "/host-usr",
        "--ro-bind", "/lib", "/lib",
        "--ro-bind", "/lib64", "/lib64",
        "--ro-bind", "/bin", "/bin",
        "--ro-bind", "/sbin", "/sbin",
        "--ro-bind", "/etc", "/etc",
        "--bind", "/tmp", "/tmp",
        "--bind", session_work, session_work,
        "--bind", f"{rootfs}/usr", "/usr",
        # Wine 11 (WineHQ) installs to /opt/wine-devel/ with hardcoded paths.
        # Mount the entire wine_dir there so all binaries, .so files, and PE DLLs
        # are found at their expected locations.
        # Wine 11's new WoW64 (PE-only) handles 32-bit PE WITHOUT needing
        # 32-bit ELF wine binary, ld-linux.so.2, or i386-unix .so files.
        "--ro-bind", wine_dir, "/opt/wine-devel",
        "--proc", "/proc",
        "--dev", "/dev"
    ]

    env = os.environ.copy()
    env["DISPLAY"] = display
    env["WINEPREFIX"] = wineprefix
    env["LD_LIBRARY_PATH"] = "/opt/wine-devel/lib/wine/x86_64-unix:/opt/wine-devel/lib/wine/x86_64-unix/extra:/usr/lib/x86_64-linux-gnu:/usr/lib"
    env["VK_ICD_FILENAMES"] = "/usr/share/vulkan/icd.d/lvp_icd.json"
    env["WINEDEBUG"] = "-all"
    env["PATH"] = "/opt/wine-devel/bin:/usr/bin:/bin"

    # Initialize wineprefix — use a template approach for speed and reliability.
    # Wine 11's wineboot hangs in bwrap (takes 30s+ and often doesn't complete).
    # Instead, we create a template wineprefix ONCE (first run), then copy it
    # for each session. This is ~10x faster and avoids the wineboot hang.
    wine_dir = get_wine_dir()
    if not os.path.lexists(os.path.join(wineprefix, "drive_c/windows/system32/user32.dll")):
        try:
            # Check if template exists; if not, create it
            if not os.path.lexists(os.path.join(WINEPREFIX_TEMPLATE, "drive_c/windows/system32/user32.dll")):
                debug_log("Creating wineprefix template (first run, ~40s)")
                os.makedirs(WINEPREFIX_TEMPLATE, exist_ok=True)
                template_env = env.copy()
                template_env["WINEPREFIX"] = WINEPREFIX_TEMPLATE
                # Disable Wine Mono and Gecko installation during wineboot.
                # The AppImage doesn't bundle Wine Mono/Gecko, so wineboot
                # would hang forever showing the "Wine Mono Installer" dialog.
                # Disabling mscoree/mshtml prevents the installer from launching.
                template_env["WINEDLLOVERRIDES"] = "mscoree=d;mshtml=d"

                # Build a special bwrap_base for template creation that binds
                # WINEPREFIX_TEMPLATE (since bwrap_base binds session_work,
                # which doesn't contain the template path)
                template_bwrap = list(bwrap_base)
                # Add WINEPREFIX_TEMPLATE as a writable bind
                template_bwrap.extend(["--bind", WINEPREFIX_TEMPLATE, WINEPREFIX_TEMPLATE])

                # Run wineboot in background with setsid, poll for user.reg
                wb_proc = subprocess.Popen(
                    template_bwrap + ["/opt/wine-devel/bin/wine", "wineboot.exe", "-u"],
                    env=template_env, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
                    preexec_fn=os.setsid
                )
                for _ in range(45):
                    time.sleep(1)
                    if os.path.exists(os.path.join(WINEPREFIX_TEMPLATE, "user.reg")):
                        break
                    if wb_proc.poll() is not None:
                        break
                # Kill wineboot process group (including wineserver)
                try:
                    os.killpg(os.getpgid(wb_proc.pid), 9)
                except Exception:
                    pass
                wb_proc.wait()
                time.sleep(2)

                user32_path = os.path.join(WINEPREFIX_TEMPLATE, "drive_c/windows/system32/user32.dll")
                if not os.path.exists(user32_path):
                    print_error("WINEBOOT_FAILED", "wineboot.exe -u failed to create system32/user32.dll in template")

                # Copy zlib1.dll (Wine 11 from WineHQ doesn't bundle it)
                subprocess.run(["cp", f"{wine_dir}/lib/wine/x86_64-windows/zlib1.dll",
                    f"{WINEPREFIX_TEMPLATE}/drive_c/windows/system32/"],
                    stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)

                # Symlink duplicate dlls to save space
                sys32 = f"{WINEPREFIX_TEMPLATE}/drive_c/windows/system32"
                src_dir = f"{wine_dir}/lib/wine/x86_64-windows"
                for f in os.listdir(sys32):
                    fp = os.path.join(sys32, f)
                    if os.path.isfile(fp) and f != "zlib1.dll":
                        if os.path.exists(os.path.join(src_dir, f)):
                            os.remove(fp)
                            os.symlink(f"/opt/wine-devel/lib/wine/x86_64-windows/{f}", fp)

                # Populate syswow64 with i386-windows DLL symlinks
                i386_src = f"{wine_dir}/lib/wine/i386-windows"
                if os.path.isdir(i386_src):
                    syswow = f"{WINEPREFIX_TEMPLATE}/drive_c/windows/syswow64"
                    os.makedirs(syswow, exist_ok=True)
                    for f in os.listdir(i386_src):
                        fp = os.path.join(syswow, f)
                        if not os.path.lexists(fp):
                            try:
                                os.symlink(f"/opt/wine-devel/lib/wine/i386-windows/{f}", fp)
                            except Exception:
                                pass
                # Mirror all COM CLSIDs from 64-bit to 32-bit (Wow6432Node) view.
                # This is critical for 32-bit games that use CoCreateInstance with
                # KEY_WOW64_32KEY (e.g. MBAA.exe uses DxDiagProvider which needs
                # dxdiagn.dll, wbemprox.dll, mmdevapi.dll registered in 32-bit view).
                # Without this, CoCreateInstance returns REGDB_E_CLASSNOTREG and
                # the game crashes with a NULL pointer dereference.
                mirror_clsids_to_wow64(WINEPREFIX_TEMPLATE, wine_dir)

                # Create .update-timestamp marker to prevent wineboot from
                # running again in sessions (which would trigger the Wine Mono
                # installer and hang). The timestamp must be newer than wine.inf.
                try:
                    wine_inf = os.path.join(wine_dir, "share", "wine", "wine.inf")
                    if os.path.exists(wine_inf):
                        ts = int(os.path.getmtime(wine_inf)) + 3600
                    else:
                        ts = int(time.time())
                    with open(os.path.join(WINEPREFIX_TEMPLATE, "drive_c", ".update-timestamp"), "w") as f:
                        f.write(str(ts))
                except Exception:
                    pass

                debug_log(f"Wineprefix template created at {WINEPREFIX_TEMPLATE}")

            # Copy template to session wineprefix (fast — just a directory copy)
            debug_log(f"Copying wineprefix template to {wineprefix}")
            shutil.copytree(WINEPREFIX_TEMPLATE, wineprefix, symlinks=True)

            # Ensure .update-timestamp exists in session prefix too (prevents
            # wineboot from running and triggering Wine Mono installer)
            try:
                ts_file = os.path.join(wineprefix, "drive_c", ".update-timestamp")
                if not os.path.exists(ts_file):
                    wine_inf = os.path.join(wine_dir, "share", "wine", "wine.inf")
                    if os.path.exists(wine_inf):
                        ts = int(os.path.getmtime(wine_inf)) + 3600
                    else:
                        ts = int(time.time())
                    with open(ts_file, "w") as f:
                        f.write(str(ts))
            except Exception:
                pass
        except Exception as e:
            print_error("WINEBOOT_FAILED", f"Failed to initialize Wine prefix: {e}")

    # 3. Launch the User application
    # Support three forms of exe_path:
    #   (a) Windows-style path inside the Wine prefix:  C:\windows\system32\notepad.exe
    #       (or any drive letter X:\... that exists in dosdevices). Translated to
    #       the host path under wineprefix/drive_X/... and passed through.
    #   (b) Unix absolute path on the host:  /home/z/my.exe  (must exist on host)
    #   (c) Relative path: resolved against cwd.
    exe_path = args.exe_path
    windows_path = None  # set if exe_path is a Windows-style path

    # Detect Windows-style path: <letter>:\...  (case-insensitive drive letter)
    if len(exe_path) >= 3 and exe_path[1] == ":" and exe_path[2] == "\\" and exe_path[0].isalpha():
        windows_path = exe_path.replace("\\", "/")  # Wine accepts forward slashes too
        # Translate C:\... -> wineprefix/drive_c/...  (lower-case drive letter)
        drive_letter = exe_path[0].lower()
        host_path = os.path.join(wineprefix, f"drive_{drive_letter}", exe_path[3:].replace("\\", "/"))
        # Use os.path.lexists (not exists) so broken symlinks still pass — many
        # wineprefix system32 DLLs are symlinks to /usr/lib/... which only resolve
        # inside the bwrap sandbox.
        if os.path.lexists(host_path):
            exe_path = host_path
        else:
            # Even if the host can't resolve the symlink, Wine will resolve it
            # inside the sandbox. Trust the user and pass the Windows path through.
            debug_log(f"Windows path {windows_path} -> host path {host_path} not directly resolvable, passing Windows path to Wine")
    else:
        if not os.path.isabs(exe_path):
            exe_path = os.path.abspath(exe_path)
        if not os.path.exists(exe_path):
            print_error("EXE_NOT_FOUND", f"Executable {exe_path} not found")

    # Detect PE architecture (i386 vs x86_64) — Wine 10's WoW64 mode handles
    # 32-bit PE binaries via the same wine64 binary, so we always use wine64.
    # The detection is reported in the JSON response so agents know which mode ran.
    if windows_path:
        pe_arch = "unknown"  # can't read the file from host
    else:
        pe_arch = detect_pe_arch(exe_path)
    wine_binary = get_wine_binary()

    exe_dir = os.path.dirname(exe_path) if not windows_path else None

    # Detect PE subsystem to decide between wine and wineconsole
    if windows_path:
        pe_subsystem = 0  # unknown
    else:
        pe_subsystem = detect_pe_subsystem(exe_path)

    # For console-subsystem apps (pe_subsystem == 3), Wine's plain 'wine' will
    # create a Unix-side console and forward the app's stdout/stderr to it.
    # We use plain wine (not wineconsole) because wineconsole --backend=curses
    # requires a real tty (not available under bwrap), and --backend=user opens
    # a GUI console window whose contents we cannot easily capture.
    # Set HEADLESS_USE_WINECONSOLE=1 to force wineconsole --backend=user if you
    # need to interact with the console window visually.
    if pe_subsystem == 3 and os.environ.get("HEADLESS_USE_WINECONSOLE") == "1":
        actual_wine_binary = "/opt/wine-devel/bin/wineconsole"
        wine_args = ["--backend=user", "--", wine_binary]
    else:
        actual_wine_binary = wine_binary
        wine_args = []

    # Re-build BWRAP arguments to include user exe path binding (only for host paths)
    # Also bind the CWD so Wine can chdir to it (Wine needs the working directory)
    cwd = os.getcwd()
    cwd_bind = ["--bind", cwd, cwd] if os.path.exists(cwd) else []
    # LIMITATION-003: --chdir sets working directory to the EXE's folder by
    # default (many games load data via relative paths). The --cwd flag
    # allows the caller to override this with a custom working directory.
    custom_cwd = getattr(args, 'cwd', None)
    if custom_cwd:
        if not os.path.exists(custom_cwd):
            print_error("CWD_NOT_FOUND", f"Custom working directory does not exist: {custom_cwd}")
        # Bind the custom cwd so bwrap can chdir to it
        cwd_bind = cwd_bind + ["--bind", custom_cwd, custom_cwd]
        chdir_arg = ["--chdir", custom_cwd]
    elif exe_dir and os.path.exists(exe_dir):
        chdir_arg = ["--chdir", exe_dir]
    else:
        chdir_arg = []
    if windows_path:
        bwrap_run = bwrap_base + cwd_bind + chdir_arg + [
            actual_wine_binary
        ] + wine_args + [windows_path] + args.args
    else:
        bwrap_run = bwrap_base + cwd_bind + chdir_arg + [
            "--bind", exe_dir, exe_dir,
            actual_wine_binary
        ] + wine_args + [exe_path] + args.args

    # Capture logs: redirect BOTH stdout and stderr of the EXE to the log file
    # (previously stdout went to /dev/null, hiding the EXE's own printf output)
    env["WINEDEBUG"] = os.environ.get("HEADLESS_WINEDEBUG", "warn+heap,err+all")

    # PATCH: Apply DLL overrides from HEADLESS_DLL_OVERRIDES env var.
    # Format: "d3dx9_36=native,builtin;d3dx9_43=native,builtin"
    # Useful when the game ships native DLLs that should override Wine's
    # builtin versions.
    dll_overrides = os.environ.get("HEADLESS_DLL_OVERRIDES", "")
    if dll_overrides:
        existing = env.get("WINEDLLOVERRIDES", "")
        for override in dll_overrides.split(";"):
            override = override.strip()
            if "=" in override:
                dll, mode = override.split("=", 1)
                if existing:
                    existing = existing + ";"
                existing = existing + f"{dll}={mode}"
        env["WINEDLLOVERRIDES"] = existing

    log_file = open(log_path, "w")
    try:
        proc = subprocess.Popen(
            bwrap_run,
            env=env,
            stdout=log_file,
            stderr=subprocess.STDOUT,
            preexec_fn=os.setsid
        )
    except Exception as e:
        print_error("LAUNCH_FAILED", f"Failed to launch process: {e}")

    # Wait for the Wine process tree to stabilize and detect early crashes.
    #
    # The previous implementation waited a fixed 2 seconds and then checked
    # /proc/{root_pid}. This was unreliable because:
    #   1. bwrap (the parent) briefly outlives the wine child, so /proc/{pid}
    #      exists even after the EXE has crashed.
    #   2. Some apps take longer than 2s to crash (e.g. during D3D9 caps init).
    #   3. The exit code of the bwrap wrapper was never consulted.
    #   4. When an EXE crashes, Wine spawns winedbg --auto which keeps the
    #      process tree alive even though the EXE itself is gone. The
    #      get_pids_for_prefix() helper returns these zombie PIDs, making
    #      the "is anything alive?" check pass falsely.
    #
    # The new implementation polls for up to HEADLESS_EXEC_WAIT seconds
    # (default 5). On each iteration it checks:
    #   - Whether bwrap has exited (proc.poll() is not None) -> definitive death
    #   - Whether any "live" wine process (excluding winedbg/wineboot/winedevice)
    #     is still running under this prefix
    #   - Whether the log file contains "Unhandled page fault" or
    #     "access violation" (strong crash signal even if winedbg holds the tree)
    # If bwrap exits OR no live wine processes remain OR the log shows a crash,
    # we treat it as a crash, read the log tail, and return PROCESS_DIED.
    exec_wait = float(os.environ.get("HEADLESS_EXEC_WAIT", "5"))
    deadline = time.time() + exec_wait
    root_pid = proc.pid
    pids = []
    crashed = False
    crash_reason = None
    bwrap_exit_code = None

    # Note: WINE_HELPER_MARKERS, live_user_pids(), and log_shows_crash() are
    # now module-level helpers (see top of file). They are shared with
    # cmd_wait_window (BUG-002 fix). The closures below are thin wrappers
    # that capture `log_file` for the flush+fsync convenience.

    def _live_user_pids(prefix_pids):
        return live_user_pids(prefix_pids)

    def _log_shows_crash(path):
        return log_shows_crash(path, file_handle=log_file)

    # Grace period: when we first see a live user PID, we don't immediately
    # declare success. Wine EXE processes can briefly appear alive even after
    # crashing (winedbg --auto attaches and keeps the process tree around).
    # We wait `grace_period` seconds (default 1.5s) after first seeing a live
    # user PID, polling the log for a crash marker. If a crash appears during
    # the grace period, we mark the session as crashed. If the grace period
    # elapses with no crash marker, the app is genuinely running.
    grace_period = float(os.environ.get("HEADLESS_EXEC_GRACE", "1.5"))
    grace_deadline = None

    while time.time() < deadline:
        bwrap_exit_code = proc.poll()
        if bwrap_exit_code is not None:
            # bwrap has exited. This is usually a crash signal, BUT for
            # console-subsystem apps Wine uses start.exe which exits
            # immediately after launching the real EXE. So before declaring
            # a crash, we:
            #   1. Wait a short grace period (0.5s) for wine processes to
            #      register under the prefix
            #   2. Check if live wine processes exist
            #   3. Check the log for crash markers
            # Only if (2) is empty AND (3) finds a marker (or log is empty
            # and no processes), do we declare a crash.
            time.sleep(0.5)  # let wine processes register
            remaining_pids = get_pids_for_prefix(wineprefix)
            live_user = _live_user_pids(remaining_pids) if remaining_pids else []
            if live_user:
                # Wine processes still alive — bwrap exit is not a crash
                # (common for console apps launched via start.exe)
                pids = remaining_pids
                bwrap_exit_code = None  # clear, not a crash
                break
            # No live user processes. Check log for crash marker.
            marker = _log_shows_crash(log_path)
            if marker:
                crashed = True
                crash_reason = f"log contains '{marker}' (bwrap exited with code {bwrap_exit_code})"
                break
            # No live processes, no crash marker, but bwrap exited.
            # This could be a very fast exit (e.g. app printed and exited
            # normally). Check if any X11 windows exist for this display —
            # if so, the app is running in the background.
            # As a last resort, treat as crash.
            crashed = True
            crash_reason = f"bwrap exited with code {bwrap_exit_code} and no wine processes remain"
            break

        # Check log for crash (always — cheap and definitive)
        marker = _log_shows_crash(log_path)
        if marker:
            crashed = True
            crash_reason = f"log contains '{marker}'"
            break

        prefix_pids = get_pids_for_prefix(wineprefix)
        if prefix_pids:
            live_user = _live_user_pids(prefix_pids)
            if live_user:
                # We see a live user PID. But Wine EXE processes can briefly
                # appear alive even after crashing (winedbg --auto attaches).
                # Start a grace period: keep polling for `grace_period`
                # seconds to see if a crash marker appears in the log.
                if grace_deadline is None:
                    grace_deadline = time.time() + grace_period
                    # Keep polling; don't break yet
                elif time.time() >= grace_deadline:
                    # Grace period elapsed with no crash marker -> genuinely running
                    pids = prefix_pids
                    break
                # else: still within grace period, keep polling
            # else: only helpers, no user PID yet -> keep polling
        time.sleep(0.2)
    else:
        # Loop exited via deadline (timeout). Do a final check.
        marker = _log_shows_crash(log_path)
        if marker:
            crashed = True
            crash_reason = f"log contains '{marker}' after {exec_wait}s timeout"
        else:
            prefix_pids = get_pids_for_prefix(wineprefix)
            if prefix_pids:
                # Live processes, no crash -> success (slow startup)
                pids = prefix_pids
            else:
                crashed = True
                crash_reason = f"no wine processes under prefix after {exec_wait}s"

    # Pick the actual wine process (not winedevice/wineserver) when possible
    if pids and not crashed:
        wine_main = None
        for p in pids:
            try:
                with open(f"/proc/{p}/cmdline", "rb") as f:
                    cmdline = f.read().replace(b"\x00", b" ").decode("utf-8", errors="ignore")
                if "wine64" in cmdline and ".exe" in cmdline:
                    wine_main = p
                    break
            except Exception:
                continue
        root_pid = wine_main or pids[0]

    # If we detected a crash, surface the error with the log tail.
    # This is the core of BUG-001: never return "ok" when the process is dead.
    if crashed or not os.path.exists(f"/proc/{root_pid}"):
        log_tail = ""
        try:
            with open(log_path, "r", errors="ignore") as f:
                log_tail = f.read()[-3000:]
        except Exception:
            pass
        reason = crash_reason or "process not found in /proc"
        # Register the session so the agent can call `headless logs` later
        # to retrieve the full log if needed.
        SessionRegistry.register(session_id, root_pid or proc.pid, display, wineprefix, log_path)
        # Mark session as crashed for `headless list` visibility
        try:
            data = SessionRegistry._load()
            if session_id in data["sessions"]:
                data["sessions"][session_id]["state"] = "crashed"
                data["sessions"][session_id]["exit_code"] = bwrap_exit_code
                data["sessions"][session_id]["crash_reason"] = reason
                SessionRegistry._save(data)
        except Exception:
            pass
        print_error(
            "PROCESS_DIED",
            f"Wine process exited before stabilizing ({reason}; bwrap exit code: {bwrap_exit_code}). "
            f"This usually means the EXE crashed on startup. "
            f"Log tail (last 3000 chars):\n{log_tail}"
        )

    # Write to registry
    SessionRegistry.register(session_id, root_pid, display, wineprefix, log_path)

    # If --wait was requested, block until a window appears or the process
    # dies. This combines exec + wait-window in one call, reducing agent
    # round-trips and avoiding the "exec says ok but app is dead" trap.
    # Returns an augmented JSON response with window info and elapsed_ms.
    if getattr(args, 'wait', False):
        wait_timeout_ms = getattr(args, 'timeout', 30000)
        wait_start = time.time()
        last_hash = None
        stable_start = None
        wait_env = os.environ.copy()
        wait_env["DISPLAY"] = display

        while (time.time() - wait_start) * 1000 < wait_timeout_ms:
            # Check if process died (reuse BUG-002 logic)
            prefix_pids = get_pids_for_prefix(wineprefix)
            if not prefix_pids:
                log_tail = ""
                try:
                    with open(log_path, "r", errors="ignore") as f:
                        log_tail = f.read()[-2000:]
                except Exception:
                    pass
                try:
                    data = SessionRegistry._load()
                    if session_id in data["sessions"]:
                        data["sessions"][session_id]["state"] = "crashed"
                        data["sessions"][session_id]["crash_reason"] = "no wine processes during --wait"
                        SessionRegistry._save(data)
                except Exception:
                    pass
                print_error(
                    "PROCESS_DIED",
                    f"Wine process exited during --wait (no wine processes under prefix). "
                    f"Log tail (last 2000 chars):\n{log_tail}"
                )
            marker = log_shows_crash(log_path)
            if marker:
                user_pids = live_user_pids(prefix_pids)
                if not user_pids:
                    log_tail = ""
                    try:
                        with open(log_path, "r", errors="ignore") as f:
                            log_tail = f.read()[-2000:]
                    except Exception:
                        pass
                    try:
                        data = SessionRegistry._load()
                        if session_id in data["sessions"]:
                            data["sessions"][session_id]["state"] = "crashed"
                            data["sessions"][session_id]["crash_reason"] = f"log contains '{marker}'"
                            SessionRegistry._save(data)
                    except Exception:
                        pass
                    print_error(
                        "PROCESS_DIED",
                        f"Wine process crashed during --wait (log contains '{marker}'). "
                        f"Log tail (last 2000 chars):\n{log_tail}"
                    )

            windows = get_windows_for_session(display, prefix_pids)
            if windows:
                w_id = windows[0]["id"]
                tmp_path = f"/tmp/wait_w_{session_id}.png"
                try:
                    subprocess.run(["import", "-window", w_id, tmp_path], env=wait_env, check=True,
                                  stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                    with open(tmp_path, "rb") as f:
                        current_hash = hashlib.md5(f.read()).hexdigest()
                    if current_hash == last_hash:
                        if not stable_start:
                            stable_start = time.time()
                        elif (time.time() - stable_start) >= 0.150:
                            elapsed = int((time.time() - wait_start) * 1000)
                            try:
                                os.remove(tmp_path)
                            except Exception:
                                pass
                            print_json({
                                "status": "ok",
                                "session_id": session_id,
                                "pid": root_pid,
                                "arch": pe_arch,
                                "subsystem": pe_subsystem,
                                "window": windows[0],
                                "elapsed_ms": elapsed
                            })
                            return
                    else:
                        last_hash = current_hash
                        stable_start = None
                except Exception:
                    pass
            else:
                last_hash = None
                stable_start = None
            time.sleep(0.05)

        # Timeout — window never stabilized
        elapsed = int((time.time() - wait_start) * 1000)
        print_json({
            "status": "timeout",
            "session_id": session_id,
            "pid": root_pid,
            "arch": pe_arch,
            "subsystem": pe_subsystem,
            "elapsed_ms": elapsed,
            "message": "Window did not stabilize within timeout. Use 'headless wait-window' to continue waiting, or 'headless screenshot' to check current state."
        })
        sys.exit(2)

    # Report architecture so the agent knows whether the EXE ran as 32-bit or 64-bit
    response = {"status": "ok", "session_id": session_id, "pid": root_pid, "arch": pe_arch, "subsystem": pe_subsystem}

    # LIMITATION-004: Warn when launching a console-subsystem app without
    # wineconsole. Console apps (subsystem 3) launched with plain 'wine'
    # don't get a Windows console, so their printf/cout output is not
    # captured to the log file. The agent should know to either set
    # HEADLESS_USE_WINECONSOLE=1 for a visible console window, or accept
    # that stdout/stderr won't appear in `headless logs`.
    if pe_subsystem == 3 and os.environ.get("HEADLESS_USE_WINECONSOLE") != "1":
        response["warning"] = (
            "Console-subsystem app launched without wineconsole. "
            "stdout/stderr may not be captured in 'headless logs'. "
            "Set HEADLESS_USE_WINECONSOLE=1 to enable a visible Wine console window."
        )

    print_json(response)


def _resolve_display(args, required_session=False):
    """Resolve display from --session (preferred) or --display, falling back to
    the first active session only if neither is provided.
    If required_session=True, raise if no session can be resolved (used by input
    commands where ambiguity between multiple sessions is dangerous)."""
    session_id = getattr(args, "session", None)
    display = getattr(args, "display", None)

    if session_id:
        sess = SessionRegistry.get(session_id)
        if not sess:
            print_error("SESSION_NOT_FOUND", f"Session {session_id} not found")
        return sess["display"]

    if display:
        return display

    sessions = SessionRegistry.list_all()
    if not sessions:
        print_error("NO_SESSION", "No active sessions. Run 'headless exec' first or pass --session.")
    if required_session and len(sessions) > 1:
        ids = list(sessions.keys())
        print_error("AMBIGUOUS_SESSION", f"Multiple sessions active ({len(sessions)}). Pass --session explicitly. IDs: {ids}")
    return list(sessions.values())[0]["display"]


def _screenshot_via_xlib(display, out_path):
    """Fallback screenshot method using python-xlib + Pillow.
    Used when ImageMagick 'import' is unavailable."""
    try:
        from Xlib.display import Display as XlibDisplay
        from Xlib import X
        from PIL import Image
    except ImportError as e:
        raise RuntimeError(f"python-xlib and Pillow are required for screenshot fallback. Install: pip install python-xlib Pillow. Original error: {e}")

    d = XlibDisplay(display)
    root = d.screen().root
    geom = root.get_geometry()
    plane_mask = 0xFFFFFFFF
    image = root.get_image(0, 0, geom.width, geom.height, X.ZPixmap, plane_mask)

    if image.depth == 24:
        img = Image.frombytes("RGB", (geom.width, geom.height), image.data, "raw", "BGRX")
    elif image.depth == 32:
        img = Image.frombytes("RGBA", (geom.width, geom.height), image.data, "raw", "BGRA")
    elif image.depth == 16:
        img = Image.frombytes("RGB", (geom.width, geom.height), image.data, "raw", "BGR;16")
    else:
        raise RuntimeError(f"Unsupported X11 depth: {image.depth}")

    img.save(out_path)


def _screenshot_blank_check(out_path):
    """Analyze a screenshot for blankness. Returns (unique_colors, warning)
    where warning is None if the screenshot looks fine, or a string warning
    if it appears blank (< 5 unique colors). Used by cmd_screenshot (BUG-006)
    so agents can distinguish 'app crashed' from 'app still loading'."""
    try:
        from PIL import Image
        img = Image.open(out_path).convert("RGB")
        # Use an iterator-based approach to avoid loading all pixels into
        # memory at once. For a 1920x1080 image, this saves ~6MB.
        # Sample every 4th pixel via crop-based iteration.
        colors = set()
        for y in range(0, img.height, 2):
            for x in range(0, img.width, 2):
                colors.add(img.getpixel((x, y)))
                if len(colors) > 100:
                    # Early exit: clearly not blank, no need to check more
                    return len(colors), None
        unique = len(colors)
        if unique < 5:
            return unique, (
                f"Screenshot appears blank ({unique} unique colors). "
                f"The process may still be loading, may have crashed, "
                f"or the display may be incorrect. Use `headless wait-window` "
                f"before screenshot, or check `headless logs` for errors."
            )
        return unique, None
    except Exception:
        return None, None


def cmd_screenshot(args):
    session_id = args.session
    out_path = args.out

    # Resolve display
    display = ":99"
    if session_id:
        sess = SessionRegistry.get(session_id)
        if not sess:
            print_error("SESSION_NOT_FOUND", f"Session {session_id} not found")
        display = sess["display"]
    else:
        # Default to first display in registry
        sessions = SessionRegistry.list_all()
        if sessions:
            display = list(sessions.values())[0]["display"]

    # PATCH: Emit a one-time-per-session warning to stderr reminding agents
    # that processes may take time to actually open and render anything visible.
    # This is printed to stderr so it does not corrupt the JSON on stdout.
    # The warning is shown only once per session via a flag file in the
    # session cache directory; set HEADLESS_NO_WAIT_WARNING=1 to suppress.
    if os.environ.get("HEADLESS_NO_WAIT_WARNING") != "1":
        try:
            if session_id:
                flag_path = os.path.join(CACHE_DIR, session_id, ".screenshot_wait_warning_shown")
            else:
                flag_path = os.path.join(CACHE_DIR, ".screenshot_wait_warning_shown")
            if not os.path.exists(flag_path):
                sys.stderr.write(
                    "[headless] Remember: processes may take some time to "
                    "actually open and render anything visible. If the "
                    "screenshot looks blank, wait a few seconds and try "
                    "again (use `headless wait-window <sess>` first).\n"
                )
                sys.stderr.flush()
                os.makedirs(os.path.dirname(flag_path), exist_ok=True)
                open(flag_path, "w").close()
        except Exception:
            pass

    if not out_path:
        out_path = f"/tmp/screenshot_{int(time.time())}.png"

    env = os.environ.copy()
    env["DISPLAY"] = display

    # Try ImageMagick 'import' first (faster); fall back to python-xlib if unavailable
    import_bin = shutil.which("import")
    if import_bin:
        try:
            subprocess.run([import_bin, "-window", "root", out_path], env=env, check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            # BUG-006: check for blank screenshot and emit warning if so
            unique_colors, warning = _screenshot_blank_check(out_path)
            response = {"status": "ok", "path": out_path}
            if unique_colors is not None:
                response["unique_colors"] = unique_colors
            if warning:
                response["warning"] = warning
            print_json(response)
            return
        except subprocess.CalledProcessError as e:
            debug_log(f"ImageMagick import failed (rc={e.returncode}), falling back to python-xlib")
        except Exception as e:
            debug_log(f"ImageMagick import raised {e}, falling back to python-xlib")

    # Fallback: python-xlib + Pillow
    try:
        _screenshot_via_xlib(display, out_path)
    except Exception as e:
        print_error("SCREENSHOT_FAILED", f"Capture failed (tried 'import' and python-xlib): {e}")

    # BUG-006: check for blank screenshot and emit warning if so
    unique_colors, warning = _screenshot_blank_check(out_path)
    response = {"status": "ok", "path": out_path}
    if unique_colors is not None:
        response["unique_colors"] = unique_colors
    if warning:
        response["warning"] = warning
    print_json(response)


def _ocr_find_text(screenshot_path, target_text, fuzzy=False):
    """Run tesseract OCR on a screenshot and find all occurrences of target_text.
    Returns a list of dicts: {text, x, y, width, height, confidence, left, top}.
    Uses PSM 11 (sparse text) with TSV output for bounding boxes.
    """
    import csv as _csv
    import io as _io

    target = target_text.lower().strip()
    matches = []

    # Run tesseract with TSV output
    tsv_path = screenshot_path.replace(".png", "_tsv")
    try:
        result = subprocess.run(
            ["tesseract", screenshot_path, tsv_path, "--psm", "11", "tsv"],
            capture_output=True, text=True, timeout=30
        )
        if result.returncode != 0:
            return []
    except Exception:
        return []

    tsv_file = tsv_path + ".tsv"
    if not os.path.exists(tsv_file):
        return []

    try:
        with open(tsv_file, "r", errors="replace") as f:
            reader = _csv.DictReader(f, delimiter="\t")
            for row in reader:
                if int(row.get("level", 0)) != 5:  # word level
                    continue
                text = row.get("text", "").lower().strip()
                conf_str = row.get("conf", "0")
                try:
                    conf = float(conf_str)
                except (ValueError, TypeError):
                    conf = 0.0
                if conf < 30:
                    continue
                if not text:
                    continue
                # Check match
                if fuzzy:
                    if target in text or text in target:
                        pass  # match
                    else:
                        continue
                else:
                    if text != target:
                        continue
                try:
                    left = int(row["left"])
                    top = int(row["top"])
                    width = int(row["width"])
                    height = int(row["height"])
                except (KeyError, ValueError):
                    continue
                matches.append({
                    "text": row.get("text", ""),
                    "x": left + width // 2,
                    "y": top + height // 2,
                    "left": left,
                    "top": top,
                    "width": width,
                    "height": height,
                    "confidence": conf,
                })
    except Exception:
        pass
    finally:
        try:
            os.remove(tsv_file)
        except Exception:
            pass

    return matches


def _ocr_find_text_in_buttons(screenshot_path, target_text, fuzzy=False):
    """Fallback for low-contrast button text: detect colored button regions
    via pixel analysis, crop each, upscale 3x, and OCR individually.
    Returns same format as _ocr_find_text but with method="button_color".
    """
    try:
        from PIL import Image
        from collections import Counter
    except ImportError:
        return []

    target = target_text.lower().strip()
    matches = []

    try:
        img = Image.open(screenshot_path).convert("RGB")
    except Exception:
        return []

    pixels = img.load()
    W, H = img.size

    # Find the dominant non-black, non-white color (likely button color)
    color_counter = Counter()
    for y in range(0, H, 4):
        for x in range(0, W, 4):
            p = pixels[x, y]
            if p[0] > 40 or p[1] > 40 or p[2] > 40:  # non-black
                if not (p[0] > 200 and p[1] > 200 and p[2] > 200):  # non-white
                    color_counter[p] += 1

    if not color_counter:
        return []

    # Try top 3 colors as potential button colors
    for btn_color, _ in color_counter.most_common(3):
        r, g, b = btn_color
        tolerance = 50

        # Find horizontal bands of this color
        color_rows = {}
        for y in range(H):
            count = 0
            for x in range(0, W, 2):
                p = pixels[x, y]
                if (abs(p[0]-r) < tolerance and abs(p[1]-g) < tolerance
                        and abs(p[2]-b) < tolerance):
                    count += 1
            if count > 20:
                color_rows[y] = count

        # Group consecutive rows into bands
        bands = []
        current_band = []
        for y in sorted(color_rows.keys()):
            if not current_band or y == current_band[-1] + 1:
                current_band.append(y)
            else:
                if len(current_band) > 8:
                    bands.append(current_band)
                current_band = [y]
        if current_band and len(current_band) > 8:
            bands.append(current_band)

        # OCR each button band
        for band in bands:
            y_start = max(0, band[0] - 5)
            y_end = min(H, band[-1] + 5)
            mid_y = (y_start + y_end) // 2
            x_start = W
            x_end = 0
            for x in range(W):
                p = pixels[x, mid_y]
                if (abs(p[0]-r) < tolerance and abs(p[1]-g) < tolerance
                        and abs(p[2]-b) < tolerance):
                    if x < x_start:
                        x_start = x
                    if x > x_end:
                        x_end = x
            if x_end <= x_start:
                continue
            x_start = max(0, x_start - 30)
            x_end = min(W, x_end + 30)

            # Crop button area (with padding above for text)
            button_crop = img.crop((x_start, max(0, y_start - 30), x_end, y_end))
            if button_crop.width < 10 or button_crop.height < 5:
                continue
            # Upscale 3x for OCR
            button_big = button_crop.resize(
                (button_crop.width * 3, button_crop.height * 3),
                Image.LANCZOS
            )
            tmp_path = f"/tmp/btn_ocr_{y_start}_{x_start}.png"
            try:
                button_big.save(tmp_path)
            except Exception:
                continue

            # OCR with PSM 7 (single line of text)
            try:
                r2 = subprocess.run(
                    ["tesseract", tmp_path, "stdout", "--psm", "7"],
                    capture_output=True, text=True, timeout=10
                )
                btn_text = r2.stdout.strip().lower()
            except Exception:
                btn_text = ""
            finally:
                try:
                    os.remove(tmp_path)
                except Exception:
                    pass

            if not btn_text:
                continue

            # Check match
            matched = False
            if fuzzy:
                if target in btn_text or btn_text in target:
                    matched = True
            else:
                if target == btn_text:
                    matched = True

            if matched:
                matches.append({
                    "text": r2.stdout.strip(),
                    "x": (x_start + x_end) // 2,
                    "y": (y_start + y_end) // 2,
                    "left": x_start,
                    "top": y_start,
                    "width": x_end - x_start,
                    "height": y_end - y_start,
                    "confidence": 50.0,
                    "method": "button_color",
                    "button_color": [r, g, b],
                })

    return matches


def cmd_find_text(args):
    """Find all occurrences of text on screen via OCR. Like click-text but
    returns all matches without clicking. Uses the same 3-tier fallback:
    1. Full-screen OCR (PSM 11)
    2. 2x upscale + retry
    3. Color-based button detection + per-button OCR
    """
    target_text = args.text
    fuzzy = getattr(args, "fuzzy", False)

    display = _resolve_display(args, required_session=True)
    env = os.environ.copy()
    env["DISPLAY"] = display

    # Take a screenshot
    screenshot_path = f"/tmp/find_text_{int(time.time())}.png"
    import_bin = shutil.which("import")
    if import_bin:
        try:
            subprocess.run([import_bin, "-window", "root", screenshot_path],
                          env=env, check=True, stdout=subprocess.DEVNULL,
                          stderr=subprocess.DEVNULL)
        except Exception as e:
            print_error("SCREENSHOT_FAILED", f"Could not capture screen for OCR: {e}")
    else:
        print_error("SCREENSHOT_FAILED", "ImageMagick 'import' not found")

    all_matches = []

    # Strategy 1: Full-screen OCR
    matches = _ocr_find_text(screenshot_path, target_text, fuzzy=fuzzy)
    for m in matches:
        m["method"] = "ocr"
        all_matches.append(m)

    # Strategy 2: Upscale 2x and retry (only if strategy 1 found nothing)
    if not all_matches:
        try:
            from PIL import Image
            img = Image.open(screenshot_path).convert("RGB")
            img_big = img.resize((img.width * 2, img.height * 2), Image.LANCZOS)
            big_path = screenshot_path.replace(".png", "_2x.png")
            img_big.save(big_path)
            big_matches = _ocr_find_text(big_path, target_text, fuzzy=fuzzy)
            for m in big_matches:
                m["x"] //= 2
                m["y"] //= 2
                m["left"] //= 2
                m["top"] //= 2
                m["width"] //= 2
                m["height"] //= 2
                m["method"] = "ocr_2x"
                all_matches.append(m)
            try:
                os.remove(big_path)
            except Exception:
                pass
        except ImportError:
            pass

    # Strategy 3: Color-based button detection (always run to find buttons
    # that full-screen OCR missed, even if strategy 1/2 found something)
    btn_matches = _ocr_find_text_in_buttons(screenshot_path, target_text, fuzzy=fuzzy)
    for m in btn_matches:
        all_matches.append(m)

    # Clean up screenshot
    try:
        os.remove(screenshot_path)
    except Exception:
        pass

    # Deduplicate matches by (x, y) — strategy 1 and 3 might find the same button
    seen = set()
    unique_matches = []
    for m in all_matches:
        key = (m["x"], m["y"])
        if key not in seen:
            seen.add(key)
            unique_matches.append(m)

    print_json({
        "status": "ok",
        "text": target_text,
        "matches": unique_matches,
        "count": len(unique_matches)
    })


def cmd_find_buttons(args):
    """Find all button-like regions on screen via color detection.
    Returns each button's bounding box, dominant color, and OCR'd text.
    Does not search for specific text — lists all detected buttons.
    """
    display = _resolve_display(args, required_session=True)
    env = os.environ.copy()
    env["DISPLAY"] = display

    # Take a screenshot
    screenshot_path = f"/tmp/find_buttons_{int(time.time())}.png"
    import_bin = shutil.which("import")
    if import_bin:
        try:
            subprocess.run([import_bin, "-window", "root", screenshot_path],
                          env=env, check=True, stdout=subprocess.DEVNULL,
                          stderr=subprocess.DEVNULL)
        except Exception as e:
            print_error("SCREENSHOT_FAILED", f"Could not capture screen: {e}")
    else:
        print_error("SCREENSHOT_FAILED", "ImageMagick 'import' not found")

    # Use the button detection logic with an empty target (match all)
    # We call _ocr_find_text_in_buttons with target="" and fuzzy=True so
    # every button is "matched" (empty string is substring of everything).
    buttons = _ocr_find_text_in_buttons(screenshot_path, "", fuzzy=True)

    # Clean up screenshot
    try:
        os.remove(screenshot_path)
    except Exception:
        pass

    # Remove the empty "text" field and rename for clarity
    for b in buttons:
        if not b.get("text"):
            b["text"] = ""

    print_json({
        "status": "ok",
        "buttons": buttons,
        "count": len(buttons)
    })


def cmd_click_text(args):
    """Find text on screen via OCR and click on it.

    Uses tesseract OCR with TSV output to find the bounding box of the
    requested text, then clicks at the center. Fallback strategy:
    1. Full-screen OCR with TSV bounding boxes (PSM 11)
    2. Upscale 2x and retry (for small text)
    3. Color-based button detection + per-button OCR (for low-contrast text)
    """
    target_text = args.text
    fuzzy = getattr(args, "fuzzy", False)
    index = getattr(args, "index", 1) - 1  # 0-based
    dry_run = getattr(args, "dry_run", False)

    display = _resolve_display(args, required_session=True)
    env = os.environ.copy()
    env["DISPLAY"] = display

    # Take a screenshot
    screenshot_path = f"/tmp/click_text_{int(time.time())}.png"
    import_bin = shutil.which("import")
    if import_bin:
        try:
            subprocess.run([import_bin, "-window", "root", screenshot_path],
                          env=env, check=True, stdout=subprocess.DEVNULL,
                          stderr=subprocess.DEVNULL)
        except Exception as e:
            print_error("SCREENSHOT_FAILED", f"Could not capture screen for OCR: {e}")
    else:
        print_error("SCREENSHOT_FAILED", "ImageMagick 'import' not found")

    # Strategy 1: Full-screen OCR
    matches = _ocr_find_text(screenshot_path, target_text, fuzzy=fuzzy)

    # Strategy 2: Upscale 2x and retry
    if not matches:
        try:
            from PIL import Image
            img = Image.open(screenshot_path).convert("RGB")
            img_big = img.resize((img.width * 2, img.height * 2), Image.LANCZOS)
            big_path = screenshot_path.replace(".png", "_2x.png")
            img_big.save(big_path)
            big_matches = _ocr_find_text(big_path, target_text, fuzzy=fuzzy)
            # Scale coordinates back to original resolution
            for m in big_matches:
                m["x"] //= 2
                m["y"] //= 2
                m["left"] //= 2
                m["top"] //= 2
                m["width"] //= 2
                m["height"] //= 2
                m["method"] = "ocr_2x"
            matches = big_matches
            try:
                os.remove(big_path)
            except Exception:
                pass
        except ImportError:
            pass

    # Strategy 3: Color-based button detection
    if not matches:
        btn_matches = _ocr_find_text_in_buttons(screenshot_path, target_text, fuzzy=fuzzy)
        matches = btn_matches

    # Clean up screenshot
    try:
        os.remove(screenshot_path)
    except Exception:
        pass

    if not matches:
        print_error(
            "TEXT_NOT_FOUND",
            f"Text '{target_text}' not found on screen via OCR. "
            f"Try --fuzzy for partial matching, or check that the text is visible "
            f"(use 'headless screenshot' to verify)."
        )

    if index >= len(matches):
        print_error(
            "INDEX_OUT_OF_RANGE",
            f"Found {len(matches)} matches for '{target_text}', but index {index+1} requested. "
            f"Matches found: {[m['text'] for m in matches[:10]]}"
        )

    match = matches[index]

    # Click at the center
    if not dry_run:
        try:
            subprocess.run(
                ["xdotool", "mousemove", str(match["x"]), str(match["y"]), "click", "1"],
                env=env, check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
            )
        except Exception as e:
            print_error("CLICK_FAILED", f"Found text but click failed: {e}")

    response = {
        "status": "ok",
        "text": match["text"],
        "x": match["x"],
        "y": match["y"],
        "width": match["width"],
        "height": match["height"],
        "confidence": match["confidence"],
        "method": match.get("method", "ocr"),
        "clicked": not dry_run,
    }
    if "button_color" in match:
        response["button_color"] = match["button_color"]
    print_json(response)


def cmd_click(args):
    # Validate bounds
    x, y = args.x, args.y
    if x < 0 or x > 1919 or y < 0 or y > 1079:
        print_error("OUT_OF_BOUNDS", f"Coordinates ({x}, {y}) exceed 1920x1080 display limits")

    display = _resolve_display(args, required_session=True)
    env = os.environ.copy()
    env["DISPLAY"] = display

    try:
        subprocess.run(["xdotool", "mousemove", str(x), str(y), "click", "1"], env=env, check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception as e:
        print_error("CLICK_FAILED", str(e))

    print_json({"status": "ok"})


def cmd_key(args):
    """Press a key or key combination. Supports multi-key combos like
    ctrl+shift+esc via xdotool's native '+' syntax (LIMITATION-006).
    xdotool's 'key' command already handles combos natively, so we just
    pass the keysym through. No need for manual keydown/keyup."""
    display = _resolve_display(args, required_session=True)
    env = os.environ.copy()
    env["DISPLAY"] = display

    keysym = args.keysym
    try:
        # xdotool 'key' natively supports combos: ctrl+shift+Escape,
        # ctrl+c, etc. No need for separate keydown/keyup.
        subprocess.run(["xdotool", "key", keysym], env=env, check=True,
                      stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception as e:
        print_error("KEY_FAILED", f"Key '{keysym}' failed: {e}")

    print_json({"status": "ok", "keysym": keysym})


def cmd_drag(args):
    """Simulate a mouse drag from (x1, y1) to (x2, y2). Useful for sliders,
    drag-and-drop, and other UI interactions (LIMITATION-006)."""
    x1, y1, x2, y2 = args.x1, args.y1, args.x2, args.y2
    # Validate bounds
    for coord, name in [(x1, "x1"), (y1, "y1"), (x2, "x2"), (y2, "y2")]:
        if coord < 0 or (name.startswith("x") and coord > 1919) or (name.startswith("y") and coord > 1079):
            print_error("OUT_OF_BOUNDS", f"Coordinate {name}={coord} exceeds display limits")

    display = _resolve_display(args, required_session=True)
    env = os.environ.copy()
    env["DISPLAY"] = display

    button = getattr(args, "button", 1)
    duration = getattr(args, "duration", 500)  # ms

    try:
        # Move to start, mouse down, move to end, mouse up
        subprocess.run(["xdotool", "mousemove", str(x1), str(y1)], env=env, check=True,
                      stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        subprocess.run(["xdotool", "mousedown", str(button)], env=env, check=True,
                      stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        # Smooth drag: move in 10 steps with small sleeps
        steps = 10
        step_delay = max(0.005, duration / 10000.0)  # convert ms to seconds
        for i in range(1, steps + 1):
            mid_x = x1 + (x2 - x1) * i // steps
            mid_y = y1 + (y2 - y1) * i // steps
            subprocess.run(["xdotool", "mousemove", str(mid_x), str(mid_y)],
                          env=env, check=True,
                          stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            time.sleep(step_delay)
        # Ensure we end at the exact target
        subprocess.run(["xdotool", "mousemove", str(x2), str(y2)], env=env, check=True,
                      stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        subprocess.run(["xdotool", "mouseup", str(button)], env=env, check=True,
                      stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception as e:
        print_error("DRAG_FAILED", str(e))

    print_json({"status": "ok", "from": {"x": x1, "y": y1}, "to": {"x": x2, "y": y2}})


def cmd_scroll(args):
    """Simulate a mouse scroll wheel event. Positive amount = scroll down,
    negative = scroll up (LIMITATION-006)."""
    amount = args.amount
    if abs(amount) > 100:
        print_error("OUT_OF_BOUNDS", f"Scroll amount {amount} too large (max 100)")

    display = _resolve_display(args, required_session=True)
    env = os.environ.copy()
    env["DISPLAY"] = display

    # xdotool click 4 = scroll up, click 5 = scroll down
    button = 5 if amount > 0 else 4
    clicks = abs(amount)

    try:
        for _ in range(clicks):
            subprocess.run(["xdotool", "click", str(button)], env=env, check=True,
                          stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception as e:
        print_error("SCROLL_FAILED", str(e))

    print_json({"status": "ok", "amount": amount, "direction": "down" if amount > 0 else "up"})


def cmd_type_unicode(args):
    """Type Unicode text via clipboard + Ctrl+V (LIMITATION-006).
    The regular 'type' command only supports ASCII. This command writes
    the text to the clipboard and pastes it with Ctrl+V."""
    text = args.text
    display = _resolve_display(args, required_session=True)
    env = os.environ.copy()
    env["DISPLAY"] = display

    # Write to clipboard via xclip
    try:
        proc = subprocess.Popen(["xclip", "-selection", "clipboard"], env=env,
                               stdin=subprocess.PIPE)
        proc.communicate(input=text.encode("utf-8"))
        if proc.returncode != 0:
            print_error("CLIPBOARD_FAILED", "Failed to write Unicode text to clipboard")
    except Exception as e:
        print_error("CLIPBOARD_FAILED", str(e))

    # Small delay for clipboard to settle
    time.sleep(0.1)

    # Paste with Ctrl+V using xdotool's native combo support
    try:
        subprocess.run(["xdotool", "key", "ctrl+v"],
                      env=env, check=True,
                      stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception as e:
        print_error("PASTE_FAILED", str(e))

    print_json({"status": "ok", "text_length": len(text)})


def cmd_type(args):
    # Enforce ASCII only
    text = args.text
    if not text.isascii():
        print_error("NON_ASCII_TEXT", "CLI typing is limited to ASCII. For Unicode, use clipboard write + Ctrl+V.")

    display = _resolve_display(args, required_session=True)
    env = os.environ.copy()
    env["DISPLAY"] = display

    try:
        subprocess.run(["xdotool", "type", "--clearmodifiers", text], env=env, check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception as e:
        print_error("TYPE_FAILED", str(e))

    print_json({"status": "ok"})


def _decode_log_bytes(data):
    """Decode Wine log bytes to text, handling UTF-16 LE output (common for
    Windows console apps like sigcheck, ipconfig, systeminfo) and the regular
    UTF-8 case. Auto-detects via BOM or null-byte pattern."""
    if not data:
        return ""
    # Check for UTF-16 LE BOM
    if data.startswith(b"\xff\xfe"):
        return data.decode("utf-16-le", errors="replace")[1:]  # strip BOM
    # Check for UTF-16 BE BOM
    if data.startswith(b"\xfe\xff"):
        return data.decode("utf-16-be", errors="replace")[1:]
    # Heuristic: count null bytes in first 100 bytes — if >30%, it's likely UTF-16 LE
    # (Windows console apps often emit UTF-16 without BOM)
    sample = data[:200]
    null_count = sample.count(b"\x00")
    if len(sample) > 10 and null_count > len(sample) * 0.25:
        try:
            decoded = data.decode("utf-16-le", errors="replace")
            # Sanity check: if decode produced a lot of replacement chars, fall back
            if decoded.count("\ufffd") < len(decoded) * 0.1:
                return decoded
        except Exception:
            pass
    # Default: UTF-8 with fallback
    return data.decode("utf-8", errors="replace")


def cmd_logs(args):
    session_id = args.session_id
    lines_count = args.lines

    sess = SessionRegistry.get(session_id)
    if not sess:
        print_error("SESSION_NOT_FOUND", f"Session {session_id} not found")

    log_path = sess["log_path"]
    if not os.path.exists(log_path):
        print_json({"status": "ok", "logs": ""})
        return

    try:
        # Read as binary so we can detect encoding
        with open(log_path, "rb") as f:
            data = f.read()
        logs_text = _decode_log_bytes(data)
        # Apply line limit on the decoded text
        if lines_count:
            lines = logs_text.splitlines(keepends=True)
            logs_text = "".join(lines[-lines_count:])
    except Exception as e:
        print_error("READ_LOGS_FAILED", str(e))

    print_json({"status": "ok", "logs": logs_text})


def cmd_kill(args):
    session_id = args.session_id
    sess = SessionRegistry.get(session_id)
    if not sess:
        print_error("SESSION_NOT_FOUND", f"Session {session_id} not found")

    wineprefix = sess["wineprefix"]
    pid = sess["pid"]

    # Kill ALL processes with this WINEPREFIX in their environ — robust against
    # reparented wineserver/winedevice processes that the old killpg approach missed.
    killed_pids = []
    for p in get_pids_for_prefix(wineprefix):
        try:
            os.kill(p, 9)
            killed_pids.append(p)
        except Exception:
            pass

    # Also try to kill the original process group as a fallback
    try:
        os.killpg(os.getpgid(pid), 9)
    except Exception:
        pass

    # BUG-008: Sweep for orphaned Wine debugger/crash-handler processes.
    # When an EXE crashes, Wine spawns `winedbg --auto` and sometimes
    # `crashdump.exe` which are NOT children of the wineprefix's processes
    # in a way that get_pids_for_prefix detects. They survive the kill
    # above and consume CPU indefinitely. Scan all processes for these
    # markers and kill any whose cmdline references this wineprefix.
    ORPHAN_MARKERS = ("winedbg", "crashdump", "crashhandler")
    for p in range(1, 65536):
        try:
            cmdline_path = f"/proc/{p}/cmdline"
            if not os.path.exists(cmdline_path):
                continue
            with open(cmdline_path, "rb") as f:
                cmdline = f.read().replace(b"\x00", b" ").decode("utf-8", errors="ignore").lower()
            # Only kill if it's an orphan marker AND references our wineprefix
            if any(marker in cmdline for marker in ORPHAN_MARKERS) and wineprefix.lower() in cmdline:
                try:
                    os.kill(p, 9)
                    killed_pids.append(p)
                except Exception:
                    pass
        except Exception:
            continue

    # Scoped wineserver -k (graceful shutdown)
    env = os.environ.copy()
    env["WINEPREFIX"] = wineprefix
    wineserver_bin = f"{get_wine_dir()}/bin/wineserver"
    if os.path.exists(wineserver_bin):
        subprocess.run([wineserver_bin, "-k"], env=env, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    # Clean Registry
    SessionRegistry.unregister(session_id)

    # Delete session cache directory
    session_work = os.path.dirname(wineprefix)
    subprocess.run(["rm", "-rf", session_work], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    print_json({"status": "ok", "killed_pids": killed_pids})


def cmd_register_dll(args):
    """Register a DLL in the wineprefix template via regsvr32.

    This runs regsvr32 against the template wineprefix (not a session copy),
    so the registration persists across all future sessions. Useful for
    registering native DirectX, COM, or other DLLs that apps need.

    Supports both Unix paths (auto-converted to Windows paths) and Windows
    paths (C:\\... style).
    """
    dll_path = args.dll_path
    arch = getattr(args, "arch", None)  # "i386", "x86_64", or None (auto)

    wine_dir = get_wine_dir()
    prefix_dir = get_prefix_dir()
    bwrap_base = [
        f"{prefix_dir}/usr/bin/bwrap",
        "--ro-bind", "/usr", "/host-usr",
        "--ro-bind", "/lib", "/lib",
        "--ro-bind", "/lib64", "/lib64",
        "--ro-bind", "/bin", "/bin",
        "--ro-bind", "/sbin", "/sbin",
        "--ro-bind", "/etc", "/etc",
        "--bind", "/tmp", "/tmp",
        # Bind the rootfs so Wine DLLs are accessible inside the sandbox
        "--ro-bind", wine_dir, "/opt/wine-devel",
        "--proc", "/proc",
        "--dev", "/dev",
    ]
    # Bind the host-debs rootfs if it exists (same as cmd_exec)
    rootfs_lib = os.path.join(prefix_dir, "usr", "lib")
    if os.path.exists(rootfs_lib):
        bwrap_base.extend(["--ro-bind", rootfs_lib, "/usr/lib"])
    rootfs_lib64 = os.path.join(prefix_dir, "usr", "lib", "x86_64-linux-gnu")
    if os.path.exists(rootfs_lib64):
        bwrap_base.extend(["--ro-bind", rootfs_lib64, "/usr/lib/x86_64-linux-gnu"])
    rootfs_share = os.path.join(prefix_dir, "usr", "share")
    if os.path.exists(rootfs_share):
        bwrap_base.extend(["--ro-bind", rootfs_share, "/usr/share"])

    # Convert Unix path to Windows path if needed
    windows_dll_path = dll_path
    if not (dll_path.startswith("C:\\") or dll_path.startswith("c:\\")):
        if not os.path.exists(dll_path):
            print_error("DLL_NOT_FOUND", f"DLL not found: {dll_path}")
        # Convert to Z:\ style path for Wine: /home/z/x.dll -> Z:\home\z\x.dll
        abs_path = os.path.abspath(dll_path)
        windows_dll_path = "Z:" + abs_path.replace("/", "\\")

    # Detect architecture if not specified
    if arch is None:
        pe_arch = detect_pe_arch(dll_path) if os.path.exists(dll_path) else "unknown"
        arch = "i386" if pe_arch == "i386" else "x86_64"

    # Bind the DLL's directory so bwrap can access it
    if os.path.exists(dll_path):
        dll_dir = os.path.dirname(os.path.abspath(dll_path))
        bwrap_base.extend(["--bind", dll_dir, dll_dir])

    # Determine which regsvr32 to use (32-bit vs 64-bit)
    if arch == "i386":
        regsvr32_path = "C:\\windows\\syswow64\\regsvr32.exe"
    else:
        regsvr32_path = "C:\\windows\\system32\\regsvr32.exe"

    env = os.environ.copy()
    env["WINEPREFIX"] = WINEPREFIX_TEMPLATE
    env["WINEDEBUG"] = os.environ.get("HEADLESS_WINEDEBUG", "-all")
    env["WINEDLLOVERRIDES"] = "mscoree=d;mshtml=d"
    env["LD_LIBRARY_PATH"] = "/opt/wine-devel/lib/wine/x86_64-unix:/opt/wine-devel/lib/wine/x86_64-unix/extra:/usr/lib/x86_64-linux-gnu:/usr/lib"
    env["PATH"] = "/opt/wine-devel/bin:/usr/bin:/bin"

    # Bind the template wineprefix
    bwrap_base.extend(["--bind", WINEPREFIX_TEMPLATE, WINEPREFIX_TEMPLATE])

    # Run regsvr32 /s (silent) on the DLL
    cmd = bwrap_base + [
        "/opt/wine-devel/bin/wine",
        regsvr32_path, "/s", windows_dll_path
    ]

    debug_log(f"register-dll: {regsvr32_path} /s {windows_dll_path} (arch={arch})")

    try:
        proc = subprocess.Popen(
            cmd, env=env,
            stdout=subprocess.PIPE, stderr=subprocess.PIPE,
            preexec_fn=os.setsid
        )
        # Wait up to 30 seconds for regsvr32
        try:
            stdout, stderr = proc.communicate(timeout=30)
            exit_code = proc.returncode
        except subprocess.TimeoutExpired:
            try:
                os.killpg(os.getpgid(proc.pid), 9)
            except Exception:
                pass
            print_error("REGISTER_TIMEOUT", f"regsvr32 timed out after 30s registering {dll_path}")

        if exit_code != 0:
            err_msg = stderr.decode("utf-8", errors="replace")[-500:] if stderr else ""
            print_error(
                "REGISTER_FAILED",
                f"regsvr32 exited with code {exit_code} registering {dll_path}. "
                f"stderr: {err_msg}"
            )
    except Exception as e:
        print_error("REGISTER_FAILED", f"Failed to run regsvr32: {e}")

    print_json({
        "status": "ok",
        "dll": dll_path,
        "windows_path": windows_dll_path,
        "arch": arch,
        "regsvr32": regsvr32_path,
        "message": f"DLL registered in template wineprefix. Future sessions will have this DLL registered."
    })


def cmd_metrics(args):
    """Return performance metrics for a session (ENHANCEMENT-002).
    Collects: process CPU/memory, uptime, wine process count, screenshot
    capture latency, and rendering FPS estimate.
    """
    session_id = args.session_id
    sess = SessionRegistry.get(session_id)
    if not sess:
        print_error("SESSION_NOT_FOUND", f"Session {session_id} not found")

    pid = sess["pid"]
    display = sess["display"]
    wineprefix = sess["wineprefix"]
    created_at = sess.get("created_at")

    # Uptime
    uptime_s = 0
    if created_at:
        try:
            from datetime import datetime, timezone
            dt = datetime.fromisoformat(created_at.replace("Z", "+00:00"))
            uptime_s = int((datetime.now(timezone.utc) - dt).total_seconds())
        except Exception:
            pass

    # Process info (CPU, memory)
    process_info = {}
    try:
        with open(f"/proc/{pid}/stat", "r") as f:
            stat = f.read().split()
        # utime + stime (in clock ticks)
        ticks = int(stat[13]) + int(stat[14])
        import os as _os
        clk_tck = _os.sysconf(_os.sysconf_names['SC_CLK_TCK'])
        cpu_time_s = ticks / clk_tck
        process_info["cpu_time_s"] = round(cpu_time_s, 2)
        # RSS (in pages)
        rss_pages = int(stat[23])
        page_size = _os.sysconf(_os.sysconf_names['SC_PAGE_SIZE'])
        rss_mb = (rss_pages * page_size) / (1024 * 1024)
        process_info["rss_mb"] = round(rss_mb, 1)
        process_info["alive"] = True
    except FileNotFoundError:
        process_info["alive"] = False
    except Exception as e:
        process_info["error"] = str(e)

    # Wine process count under this prefix
    wine_pids = get_pids_for_prefix(wineprefix)
    user_pids = live_user_pids(wine_pids)
    process_info["wine_process_count"] = len(wine_pids)
    process_info["user_process_count"] = len(user_pids)

    # Screenshot latency (measure time to capture + count colors)
    screenshot_metrics = {}
    env = os.environ.copy()
    env["DISPLAY"] = display
    screenshot_path = f"/tmp/metrics_{session_id}_{int(time.time())}.png"
    import_bin = shutil.which("import")
    if import_bin and process_info.get("alive"):
        try:
            t0 = time.time()
            subprocess.run([import_bin, "-window", "root", screenshot_path],
                          env=env, check=True, stdout=subprocess.DEVNULL,
                          stderr=subprocess.DEVNULL, timeout=10)
            t1 = time.time()
            screenshot_metrics["capture_ms"] = round((t1 - t0) * 1000, 1)

            # Count unique colors (sampled)
            try:
                from PIL import Image
                img = Image.open(screenshot_path).convert("RGB")
                pixels = list(img.getdata())[::16]  # sample every 16th pixel
                screenshot_metrics["unique_colors_sampled"] = len(set(pixels))
            except Exception:
                pass

            os.remove(screenshot_path)
        except Exception as e:
            screenshot_metrics["error"] = str(e)

    # Session state
    state = sess.get("state", "running")

    print_json({
        "status": "ok",
        "session_id": session_id,
        "pid": pid,
        "state": state,
        "uptime_s": uptime_s,
        "process": process_info,
        "screenshot": screenshot_metrics
    })


def cmd_list(args):
    sessions = SessionRegistry.list_all()
    active_sessions = []

    for sess_id, info in list(sessions.items()):
        # Check if root PID is still alive
        pid = info["pid"]
        alive = os.path.exists(f"/proc/{pid}")

        # Don't auto-delete dead sessions — mark them so the agent can still
        # inspect logs via 'headless logs <sess_id>' before they're gc'd.
        # Use 'headless gc' to remove dead sessions explicitly.
        # Preserve the state from the registry (e.g. "crashed") instead of
        # always overwriting with "running"/"dead". If the registry state is
        # "running" but the PID is gone, fall back to "dead".
        reg_state = info.get("state", "running")
        if reg_state == "running" and not alive:
            effective_state = "dead"
        else:
            effective_state = reg_state

        active_sessions.append({
            "session_id": sess_id,
            "pid": pid,
            "display": info["display"],
            "wineprefix": info["wineprefix"],
            "created_at": info["created_at"],
            "state": effective_state
        })

    print_json({"status": "ok", "sessions": active_sessions})


def cmd_clipboard(args):
    display = _resolve_display(args, required_session=False)
    env = os.environ.copy()
    env["DISPLAY"] = display

    # Retries for async X11 clipboards
    max_retries = 3

    if args.write is not None:
        text = args.write
        for attempt in range(max_retries):
            try:
                proc = subprocess.Popen(["xclip", "-selection", "clipboard", "-in"], env=env, stdin=subprocess.PIPE, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                proc.communicate(input=text.encode("utf-8"))
                if proc.returncode == 0:
                    break
            except Exception:
                time.sleep(0.1)
        print_json({"status": "ok"})
    else:
        # Read clipboard
        clip_text = ""
        for attempt in range(max_retries):
            try:
                res = subprocess.run(["xclip", "-selection", "clipboard", "-out"], env=env, capture_output=True, text=True)
                if res.returncode == 0:
                    clip_text = res.stdout
                    break
            except Exception:
                time.sleep(0.1)
        print_json({"status": "ok", "text": clip_text})


def _resolve_wine_path(wineprefix, windows_path):
    """Convert a Windows path (C:\\users\\...) to a Unix path inside the
    wineprefix's drive_c directory. Supports C:\\ and Z:\\ (host paths)."""
    # Normalize separators
    wp = windows_path.replace("/", "\\")
    # Check drive letter
    if len(wp) >= 2 and wp[1] == ":":
        drive = wp[0].lower()
        rest = wp[2:].lstrip("\\")
        if drive == "z":
            # Z:\ maps to host filesystem directly
            return "/" + rest.replace("\\", "/")
        elif drive == "c":
            # C:\ maps to wineprefix/drive_c/
            return os.path.join(wineprefix, "drive_c", rest.replace("\\", "/"))
        else:
            # Other drives (D:, E:, etc.) — check dosdevices
            dosdevice = os.path.join(wineprefix, "dosdevices", drive + ":")
            if os.path.lexists(dosdevice):
                real = os.path.realpath(dosdevice)
                return os.path.join(real, rest.replace("\\", "/"))
    return None


def cmd_file_read(args):
    """Read a file inside the Wine prefix's C:\\ drive (or any mapped drive).
    Accepts Windows paths (C:\\users\\...) or Unix paths."""
    file_path = args.path
    session_id = args.session

    sess = SessionRegistry.get(session_id)
    if not sess:
        print_error("SESSION_NOT_FOUND", f"Session {session_id} not found")

    wineprefix = sess["wineprefix"]

    # Try to resolve as Windows path first
    unix_path = _resolve_wine_path(wineprefix, file_path)
    if unix_path is None or not os.path.exists(unix_path):
        # Try as direct Unix path
        if os.path.exists(file_path):
            unix_path = file_path
        else:
            print_error("FILE_NOT_FOUND",
                f"File not found: {file_path} (resolved to {unix_path})")

    if not os.path.isfile(unix_path):
        print_error("NOT_A_FILE", f"Path is not a regular file: {file_path}")

    # Check file size (limit to 1MB to avoid huge outputs)
    file_size = os.path.getsize(unix_path)
    max_size = 1024 * 1024  # 1MB
    truncated = False
    if file_size > max_size:
        truncated = True

    try:
        with open(unix_path, "rb") as f:
            data = f.read(max_size)
    except Exception as e:
        print_error("READ_FAILED", f"Failed to read {file_path}: {e}")

    # Try to decode as text
    text = None
    for encoding in ("utf-8", "utf-16-le", "utf-16-be", "latin-1", "ascii"):
        try:
            text = data.decode(encoding)
            detected_encoding = encoding
            break
        except (UnicodeDecodeError, ValueError):
            continue

    response = {
        "status": "ok",
        "path": file_path,
        "resolved": unix_path,
        "size": file_size,
        "truncated": truncated,
    }

    if text is not None:
        response["encoding"] = detected_encoding
        response["text"] = text
    else:
        # Binary file — return base64
        import base64
        response["encoding"] = "base64"
        response["data"] = base64.b64encode(data).decode("ascii")

    print_json(response)


def cmd_file_write(args):
    """Write text to a file inside the Wine prefix's C:\\ drive."""
    file_path = args.path
    content = args.content
    session_id = args.session

    sess = SessionRegistry.get(session_id)
    if not sess:
        print_error("SESSION_NOT_FOUND", f"Session {session_id} not found")

    wineprefix = sess["wineprefix"]

    unix_path = _resolve_wine_path(wineprefix, file_path)
    if unix_path is None:
        print_error("INVALID_PATH", f"Could not resolve path: {file_path}")

    # Create parent directories if needed
    parent = os.path.dirname(unix_path)
    if parent and not os.path.exists(parent):
        try:
            os.makedirs(parent, exist_ok=True)
        except Exception as e:
            print_error("MKDIR_FAILED", f"Failed to create directory: {e}")

    try:
        with open(unix_path, "w") as f:
            f.write(content)
    except Exception as e:
        print_error("WRITE_FAILED", f"Failed to write {file_path}: {e}")

    print_json({"status": "ok", "path": file_path, "resolved": unix_path, "bytes_written": len(content)})


def cmd_diff(args):
    """Take two screenshots with an interval and compare them.
    Returns the percentage of pixels that changed. Useful for detecting
    whether the screen is animating/loading or static/hung."""
    display = _resolve_display(args, required_session=True)
    env = os.environ.copy()
    env["DISPLAY"] = display

    interval = getattr(args, 'interval', 1.0)
    threshold = getattr(args, 'threshold', 1.0)  # % of pixels that must differ
    import_bin = shutil.which("import")

    if not import_bin:
        print_error("SCREENSHOT_FAILED", "ImageMagick 'import' not found")

    shot1 = f"/tmp/diff_1_{int(time.time())}.png"
    shot2 = f"/tmp/diff_2_{int(time.time())}.png"

    # Capture first frame
    try:
        subprocess.run([import_bin, "-window", "root", shot1],
                      env=env, check=True, stdout=subprocess.DEVNULL,
                      stderr=subprocess.DEVNULL)
    except Exception as e:
        print_error("SCREENSHOT_FAILED", f"First capture failed: {e}")

    # Wait
    time.sleep(interval)

    # Capture second frame
    try:
        subprocess.run([import_bin, "-window", "root", shot2],
                      env=env, check=True, stdout=subprocess.DEVNULL,
                      stderr=subprocess.DEVNULL)
    except Exception as e:
        print_error("SCREENSHOT_FAILED", f"Second capture failed: {e}")

    # Compare
    try:
        from PIL import Image
        img1 = Image.open(shot1).convert("RGB")
        img2 = Image.open(shot2).convert("RGB")

        # Ensure same size
        if img1.size != img2.size:
            print_error("SIZE_MISMATCH",
                f"Screenshot sizes differ: {img1.size} vs {img2.size}")

        # Sample every 4th pixel for speed
        w, h = img1.size
        total = 0
        changed = 0
        for y in range(0, h, 2):
            for x in range(0, w, 2):
                p1 = img1.getpixel((x, y))
                p2 = img2.getpixel((x, y))
                total += 1
                if abs(p1[0]-p2[0]) > 10 or abs(p1[1]-p2[1]) > 10 or abs(p1[2]-p2[2]) > 10:
                    changed += 1

        diff_percent = (changed / total * 100) if total > 0 else 0
        is_changed = diff_percent > threshold
    except Exception as e:
        print_error("DIFF_FAILED", str(e))
    finally:
        try:
            os.remove(shot1)
            os.remove(shot2)
        except Exception:
            pass

    print_json({
        "status": "ok",
        "changed": is_changed,
        "diff_percent": round(diff_percent, 2),
        "diff_pixels_sampled": changed,
        "total_pixels_sampled": total,
        "threshold_percent": threshold,
        "interval_s": interval,
        "message": "Screen changed" if is_changed else "Screen unchanged"
    })


def cmd_wait_stable(args):
    """Wait until the screen stops changing (consecutive frames are
    identical within a threshold). Useful for waiting until loading
    screens, transitions, or animations complete."""
    display = _resolve_display(args, required_session=True)
    env = os.environ.copy()
    env["DISPLAY"] = display

    timeout_ms = getattr(args, 'timeout', 15000)
    stable_frames = getattr(args, 'stable_frames', 3)  # consecutive identical frames
    poll_interval = getattr(args, 'poll_interval', 0.5)  # seconds between captures
    threshold = getattr(args, 'threshold', 0.5)  # % of pixels that must differ to count as "changed"
    import_bin = shutil.which("import")

    if not import_bin:
        print_error("SCREENSHOT_FAILED", "ImageMagick 'import' not found")

    start_time = time.time()
    consecutive_stable = 0
    frames_checked = 0
    prev_pixels = None

    from PIL import Image

    while (time.time() - start_time) * 1000 < timeout_ms:
        shot = f"/tmp/stable_{int(time.time()*1000)}.png"
        try:
            subprocess.run([import_bin, "-window", "root", shot],
                          env=env, check=True, stdout=subprocess.DEVNULL,
                          stderr=subprocess.DEVNULL, timeout=5)
        except Exception:
            time.sleep(poll_interval)
            continue

        try:
            img = Image.open(shot).convert("RGB")
            w, h = img.size
            # Sample pixels for comparison
            curr_pixels = []
            for y in range(0, h, 8):
                for x in range(0, w, 8):
                    curr_pixels.append(img.getpixel((x, y)))

            if prev_pixels is not None:
                total = len(curr_pixels)
                changed = sum(1 for a, b in zip(curr_pixels, prev_pixels)
                            if abs(a[0]-b[0]) > 10 or abs(a[1]-b[1]) > 10 or abs(a[2]-b[2]) > 10)
                diff_percent = (changed / total * 100) if total > 0 else 0

                if diff_percent < threshold:
                    consecutive_stable += 1
                else:
                    consecutive_stable = 0

                frames_checked += 1

                if consecutive_stable >= stable_frames:
                    elapsed = int((time.time() - start_time) * 1000)
                    try:
                        os.remove(shot)
                    except Exception:
                        pass
                    print_json({
                        "status": "ok",
                        "stable": True,
                        "elapsed_ms": elapsed,
                        "frames_checked": frames_checked,
                        "consecutive_stable": consecutive_stable,
                        "message": "Screen has stabilized"
                    })
                    return
            else:
                frames_checked += 1

            prev_pixels = curr_pixels
        except Exception:
            pass

        try:
            os.remove(shot)
        except Exception:
            pass

        time.sleep(poll_interval)

    # Timeout
    elapsed = int((time.time() - start_time) * 1000)
    print_json({
        "status": "timeout",
        "stable": False,
        "elapsed_ms": elapsed,
        "frames_checked": frames_checked,
        "consecutive_stable": consecutive_stable,
        "message": "Screen did not stabilize within timeout"
    })
    sys.exit(2)


def cmd_windows(args):
    display = _resolve_display(args, required_session=False)
    env = os.environ.copy()
    env["DISPLAY"] = display

    # If --session is specified, use get_windows_for_session which has the
    # BUG-007 fallback logic (WM_CLASS matching + dialog title matching).
    # This catches modal dialogs whose _NET_WM_PID doesn't match the
    # wineprefix's PIDs.
    requested_session = getattr(args, 'session', None)
    if requested_session:
        sess = SessionRegistry.get(requested_session)
        if not sess:
            print_error("SESSION_NOT_FOUND", f"Session {requested_session} not found")
        wineprefix = sess["wineprefix"]
        prefix_pids = get_pids_for_prefix(wineprefix)
        # Determine exe_basename from the session's cmdline (if available)
        exe_basename = None
        try:
            with open(f"/proc/{sess['pid']}/cmdline", "rb") as f:
                cmdline = f.read().replace(b"\x00", b" ").decode("utf-8", errors="ignore")
            # Extract the .exe filename from the cmdline
            import re as _re
            m = _re.search(r'([A-Za-z0-9_-]+\.exe)', cmdline, _re.IGNORECASE)
            if m:
                exe_basename = m.group(1)
        except Exception:
            pass
        windows_raw = get_windows_for_session(display, prefix_pids, exe_basename=exe_basename)
        # Enrich with modal detection and session_id
        windows = []
        for w in windows_raw:
            is_modal = False
            try:
                xprop_res = subprocess.run(
                    ["xprop", "-id", w["id"], "_NET_WM_STATE", "_NET_WM_WINDOW_TYPE"],
                    env=env, capture_output=True, text=True, timeout=2
                )
                if xprop_res.returncode == 0:
                    if "_NET_WM_STATE_ABOVE" in xprop_res.stdout or "_NET_WM_WINDOW_TYPE_DIALOG" in xprop_res.stdout:
                        is_modal = True
            except Exception:
                pass
            windows.append({
                "id": w["id"],
                "pid": w.get("pid", 0),
                "session_id": requested_session,
                "title": w["title"],
                "type": "modal" if is_modal else "normal",
                "matched_by": w.get("matched_by", "pid")
            })
        print_json({"status": "ok", "windows": windows})
        return

    # No --session: list ALL windows across ALL sessions (original behavior)
    sessions = SessionRegistry.list_all()
    all_pids = []
    pid_to_session = {}
    for sess_id, info in sessions.items():
        wineprefix = info["wineprefix"]
        prefix_pids = get_pids_for_prefix(wineprefix)
        for p in prefix_pids:
            all_pids.append(p)
            pid_to_session[p] = sess_id

    try:
        # list visible windows
        res = subprocess.run(["wmctrl", "-l", "-p"], env=env, capture_output=True, text=True)
        if res.returncode != 0:
            print_json({"status": "ok", "windows": []})
            return

        windows = []
        for line in res.stdout.splitlines():
            parts = line.split(None, 4)
            if len(parts) >= 4:
                w_id = parts[0]
                try:
                    pid = int(parts[2])
                except (ValueError, IndexError):
                    pid = 0
                title = parts[4] if len(parts) > 4 else ""

                # Check modal type using xprop
                is_modal = False
                try:
                    xprop_res = subprocess.run(
                        ["xprop", "-id", w_id, "_NET_WM_STATE", "_NET_WM_WINDOW_TYPE"],
                        env=env, capture_output=True, text=True, timeout=2
                    )
                    if xprop_res.returncode == 0:
                        if "_NET_WM_STATE_ABOVE" in xprop_res.stdout or "_NET_WM_WINDOW_TYPE_DIALOG" in xprop_res.stdout:
                            is_modal = True
                except Exception:
                    pass

                session_id = pid_to_session.get(pid, "unknown")
                windows.append({
                    "id": w_id,
                    "pid": pid,
                    "session_id": session_id,
                    "title": title,
                    "type": "modal" if is_modal else "normal"
                })
        print_json({"status": "ok", "windows": windows})
    except Exception as e:
        print_error("WINDOWS_LIST_FAILED", str(e))


def cmd_focus(args):
    session_id = args.session_id
    sess = SessionRegistry.get(session_id)
    if not sess:
        print_error("SESSION_NOT_FOUND", f"Session {session_id} not found")

    display = sess["display"]
    wineprefix = sess["wineprefix"]
    env = os.environ.copy()
    env["DISPLAY"] = display

    pids = get_pids_for_prefix(wineprefix)
    windows = get_windows_for_session(display, pids)
    if not windows:
        print_error("NO_WINDOW_FOUND", f"No open windows found for session {session_id}")

    # Focus the first matching window
    w_id = windows[0]["id"]
    try:
        subprocess.run(["xdotool", "windowactivate", w_id], env=env, check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception as e:
        print_error("FOCUS_FAILED", str(e))

    print_json({"status": "ok"})


def cmd_accept_dialog(args):
    """Auto-accept a modal dialog (EULA, OK/Cancel prompt, etc.) by pressing
    Enter on the foreground window. Most Windows modal dialogs have the
    "Accept"/"OK"/"Yes" button as the default button, so Enter activates it.

    For EULA dialogs that require multiple clicks, run this command multiple
    times, or use --clicks N to press Enter N times with a delay between.

    This is a best-effort heuristic — for dialogs with non-default button
    layouts, use 'headless click X Y' to click a specific button by position."""
    session_id = args.session_id
    sess = SessionRegistry.get(session_id)
    if not sess:
        print_error("SESSION_NOT_FOUND", f"Session {session_id} not found")

    display = sess["display"]
    wineprefix = sess["wineprefix"]
    env = os.environ.copy()
    env["DISPLAY"] = display

    # Find the foreground window
    pids = get_pids_for_prefix(wineprefix)
    windows = get_windows_for_session(display, pids)
    if not windows:
        print_error("NO_WINDOW_FOUND", f"No open windows found for session {session_id}")

    # Focus the most recent window (usually the modal dialog)
    w_id = windows[-1]["id"]  # last = most recently created = likely the dialog
    try:
        subprocess.run(["xdotool", "windowactivate", w_id], env=env, check=True,
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        time.sleep(0.2)
    except Exception as e:
        print_error("FOCUS_FAILED", f"Failed to focus dialog: {e}")

    clicks = args.clicks or 1
    delay = args.delay or 0.3
    accepted_count = 0
    for i in range(clicks):
        try:
            # Press Enter (Return) — activates the default button
            subprocess.run(["xdotool", "key", "Return"], env=env, check=True,
                           stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            accepted_count += 1
            time.sleep(delay)
        except Exception as e:
            debug_log(f"accept-dialog: key press {i+1} failed: {e}")
            break

    print_json({"status": "ok", "pressed_enter_count": accepted_count,
                "window_id": w_id, "window_title": windows[-1].get("title", "")})


def cmd_wait_window(args):
    session_id = args.session_id
    timeout_ms = args.timeout or 10000 # default 10s
    start_time = time.time()

    sess = SessionRegistry.get(session_id)
    if not sess:
        print_error("SESSION_NOT_FOUND", f"Session {session_id} not found")

    display = sess["display"]
    wineprefix = sess["wineprefix"]
    log_path = sess.get("log_path", f"/tmp/wine_debug_{session_id}.log")
    env = os.environ.copy()
    env["DISPLAY"] = display

    last_hash = None
    stable_start = None

    while (time.time() - start_time) * 1000 < timeout_ms:
        # BUG-002 fix: check if the process has died before continuing to
        # poll for windows. Previously, wait-window would wait the full
        # timeout even if the EXE crashed at t=2s, returning "timeout" —
        # indistinguishable from a slow-loading app.
        #
        # We check two signals:
        #   1. No wine processes under the prefix at all -> definitely dead
        #   2. Only Wine helper processes alive AND log shows crash marker
        #      -> EXE crashed but winedbg/wineserver are still cleaning up
        prefix_pids = get_pids_for_prefix(wineprefix)
        if not prefix_pids:
            # No wine processes at all — process tree is gone
            log_tail = ""
            try:
                with open(log_path, "r", errors="ignore") as f:
                    log_tail = f.read()[-2000:]
            except Exception:
                pass
            # Mark session as crashed in the registry
            try:
                data = SessionRegistry._load()
                if session_id in data["sessions"]:
                    data["sessions"][session_id]["state"] = "crashed"
                    data["sessions"][session_id]["crash_reason"] = "no wine processes during wait-window"
                    SessionRegistry._save(data)
            except Exception:
                pass
            print_error(
                "PROCESS_DIED",
                f"Wine process exited during wait-window (no wine processes under prefix). "
                f"The EXE likely crashed. Log tail (last 2000 chars):\n{log_tail}"
            )
        # Check for crash in log even if helper PIDs exist (winedbg keeps
        # zombie processes alive). This catches the common case where the
        # EXE crashed but winedbg --auto is still attached.
        marker = log_shows_crash(log_path)
        if marker:
            # Verify that no live USER process exists (only helpers)
            user_pids = live_user_pids(prefix_pids)
            if not user_pids:
                log_tail = ""
                try:
                    with open(log_path, "r", errors="ignore") as f:
                        log_tail = f.read()[-2000:]
                except Exception:
                    pass
                try:
                    data = SessionRegistry._load()
                    if session_id in data["sessions"]:
                        data["sessions"][session_id]["state"] = "crashed"
                        data["sessions"][session_id]["crash_reason"] = f"log contains '{marker}'"
                        SessionRegistry._save(data)
                except Exception:
                    pass
                print_error(
                    "PROCESS_DIED",
                    f"Wine process crashed during wait-window (log contains '{marker}'). "
                    f"Log tail (last 2000 chars):\n{log_tail}"
                )

        windows = get_windows_for_session(display, prefix_pids)

        if windows:
            w_id = windows[0]["id"]
            # Capture for pixel stability
            tmp_path = f"/tmp/wait_w_{session_id}.png"
            try:
                subprocess.run(["import", "-window", w_id, tmp_path], env=env, check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                with open(tmp_path, "rb") as f:
                    current_hash = hashlib.md5(f.read()).hexdigest()

                if current_hash == last_hash:
                    if not stable_start:
                        stable_start = time.time()
                    elif (time.time() - stable_start) >= 0.150: # 150ms stable
                        # Stable!
                        elapsed = int((time.time() - start_time) * 1000)
                        os.remove(tmp_path)
                        print_json({"status": "ok", "elapsed_ms": elapsed})
                        return
                else:
                    last_hash = current_hash
                    stable_start = None
            except Exception:
                pass
        else:
            last_hash = None
            stable_start = None

        time.sleep(0.05) # poll every 50ms

    print_json({"status": "timeout"})
    sys.exit(2) # exit code 2 on timeout


# --- Integrated Verification ---

def run_verify(args):
    """Integrated smoke test: init display → exec dx9_triangle.exe → wait-window
    → screenshot → kill → analyze colors. Returns exit code 0 on pass, 1 on fail.
    Each step aborts early with a clear error so the agent doesn't get confusing
    downstream failures from a missing window."""
    print("=== HeadlessLab — Smoke Test (Integrated in CLI) ===")

    # 1. Kill old processes
    pkill_proc = subprocess.Popen(["pkill", "-9", "-f", "wine64.*\\.exe"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    pkill_proc.wait()
    pkill_server = subprocess.Popen(["pkill", "-9", "-f", "wineserver"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    pkill_server.wait()
    time.sleep(1)

    appdir = get_appdir()
    triangle_exe = os.path.join(appdir, "examples/dx9_triangle.exe")
    screenshot_path = "/tmp/verify_screenshot.png"
    if os.path.exists(screenshot_path):
        os.remove(screenshot_path)

    # 2. Init display via shared helper (no more duplicated Xvfb/Openbox code)
    print(">> Initializing display...")
    display = find_free_display()
    geometry = "1920x1080x24"
    ok, err = _start_display(display, geometry)
    if not ok:
        print(f"[FAIL] Display init failed: {err}")
        sys.exit(1)

    # 3. Exec triangle
    print(">> Initializing WINEPREFIX and running example...")
    exec_args = argparse.Namespace(
        exe_path=triangle_exe,
        display=display,
        cwd=None,
        wait=False,
        timeout=30000,
        args=[]
    )
    cmd_exec(exec_args)

    # Wait for session registration
    time.sleep(1)
    sessions = SessionRegistry.list_all()
    if not sessions:
        print("[FAIL] No session registered after exec. Wine failed to start.")
        # Clean up display
        subprocess.run(["pkill", "-9", "-f", f"Xvfb {display}"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        sys.exit(1)
    session_id = list(sessions.keys())[-1]  # pick last session

    # 4. Wait window stability — abort cleanly on timeout instead of continuing
    print(">> Waiting for triangle stability...")
    wait_args = argparse.Namespace(
        session_id=session_id,
        timeout=15000
    )
    try:
        cmd_wait_window(wait_args)
    except SystemExit as se:
        if se.code != 0:
            print(f"[FAIL] Waiting for window timed out (exit code {se.code}).")
            # Still kill the session and clean up
            kill_args = argparse.Namespace(session_id=session_id)
            try:
                cmd_kill(kill_args)
            except Exception:
                pass
            subprocess.run(["pkill", "-9", "-f", f"Xvfb {display}"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            subprocess.run(["pkill", "-9", "-f", f"openbox.*{display}"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            sys.exit(1)

    # 5. Screenshot
    print(">> Capturing screenshot...")
    screenshot_args = argparse.Namespace(
        session=session_id,
        out=screenshot_path
    )
    cmd_screenshot(screenshot_args)

    # 6. Kill session
    print(">> Terminating session...")
    kill_args = argparse.Namespace(
        session_id=session_id
    )
    cmd_kill(kill_args)

    # Kill Xvfb/Openbox processes of this test run
    subprocess.run(["pkill", "-9", "-f", f"Xvfb {display}"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    subprocess.run(["pkill", "-9", "-f", f"openbox.*{display}"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    # 7. Analyze
    print(">> Analyzing rendering...")
    from PIL import Image
    try:
        img = Image.open(screenshot_path)
        colors = img.getcolors(maxcolors=1024*1024)
        if not colors:
            print("[FAIL] No colors found in screenshot.")
            sys.exit(1)
        n = len(colors)
        print(f"Unique colors: {n}")
        if n > 100:
            print(f"[OK] Smoke Test PASS! The runtime is working perfectly ({n} colors > 100)!")
        else:
            print(f"[FAIL] Smoke Test FAIL! Too few colors ({n} <= 100).")
            sys.exit(1)
    except Exception as e:
        print(f"[FAIL] Verify analysis failed: {e}")
        sys.exit(1)

    # 8. ENHANCEMENT-003: Additional verification cases
    # Test 32-bit DX9 triangle (exercises WoW64 rendering)
    triangle_32_exe = os.path.join(appdir, "examples/dx9_triangle_32.exe")
    if os.path.exists(triangle_32_exe):
        print(">> Testing 32-bit DX9 rendering (WoW64)...")
        display2 = find_free_display()
        ok2, err2 = _start_display(display2, geometry)
        if ok2:
            try:
                exec_args2 = argparse.Namespace(
                    exe_path=triangle_32_exe,
                    display=display2,
                    cwd=None,
                    wait=False,
                    timeout=30000,
                    args=[]
                )
                # Capture stdout to suppress JSON
                import io as _io, contextlib as _ctx
                with _ctx.redirect_stdout(_io.StringIO()):
                    cmd_exec(exec_args2)
                time.sleep(2)
                sessions2 = SessionRegistry.list_all()
                if sessions2:
                    sess2_id = list(sessions2.keys())[-1]
                    wait_args2 = argparse.Namespace(session_id=sess2_id, timeout=10000)
                    try:
                        with _ctx.redirect_stdout(_io.StringIO()):
                            cmd_wait_window(wait_args2)
                    except SystemExit:
                        pass
                    # Screenshot
                    screenshot2 = "/tmp/verify_32bit.png"
                    env2 = os.environ.copy()
                    env2["DISPLAY"] = display2
                    import_bin = shutil.which("import")
                    if import_bin:
                        subprocess.run([import_bin, "-window", "root", screenshot2],
                                      env=env2, check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                        try:
                            img2 = Image.open(screenshot2)
                            colors2 = img2.getcolors(maxcolors=1024*1024)
                            n2 = len(colors2) if colors2 else 0
                            if n2 > 50:
                                print(f"  [OK] 32-bit DX9: {n2} colors (WoW64 rendering works)")
                            else:
                                print(f"  [WARN] 32-bit DX9: only {n2} colors (may need investigation)")
                        except Exception:
                            print("  [WARN] 32-bit DX9: could not analyze screenshot")
                    # Kill
                    kill_args2 = argparse.Namespace(session_id=sess2_id)
                    try:
                        with _ctx.redirect_stdout(_io.StringIO()):
                            cmd_kill(kill_args2)
                    except Exception:
                        pass
                subprocess.run(["pkill", "-9", "-f", f"Xvfb {display2}"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                subprocess.run(["pkill", "-9", "-f", f"openbox.*{display2}"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            except Exception as e:
                print(f"  [WARN] 32-bit DX9 test failed: {e}")
                subprocess.run(["pkill", "-9", "-f", f"Xvfb {display2}"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    # Test console app (hello_win.exe) — verifies stdout capture
    hello_exe = os.path.join(appdir, "examples/hello_win.exe")
    if os.path.exists(hello_exe):
        print(">> Testing console app stdout capture...")
        display3 = find_free_display()
        ok3, err3 = _start_display(display3, geometry)
        if ok3:
            try:
                exec_args3 = argparse.Namespace(
                    exe_path=hello_exe,
                    display=display3,
                    cwd=None,
                    wait=False,
                    timeout=30000,
                    args=[]
                )
                import io as _io2, contextlib as _ctx2
                with _ctx2.redirect_stdout(_io2.StringIO()):
                    cmd_exec(exec_args3)
                time.sleep(3)
                sessions3 = SessionRegistry.list_all()
                if sessions3:
                    sess3_id = list(sessions3.keys())[-1]
                    # Check logs
                    log_args = argparse.Namespace(session_id=sess3_id, lines=20)
                    try:
                        with _ctx2.redirect_stdout(_io2.StringIO()):
                            cmd_logs(log_args)
                    except SystemExit:
                        pass
                    # Kill
                    kill_args3 = argparse.Namespace(session_id=sess3_id)
                    try:
                        with _ctx2.redirect_stdout(_io2.StringIO()):
                            cmd_kill(kill_args3)
                    except Exception:
                        pass
                print("  [OK] Console app launched (subsystem detection works)")
            except Exception as e:
                print(f"  [WARN] Console app test failed: {e}")
            subprocess.run(["pkill", "-9", "-f", f"Xvfb {display3}"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            subprocess.run(["pkill", "-9", "-f", f"openbox.*{display3}"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    print(">> All smoke tests complete.")


# --- Main CLI Entrypoint ---

HEADLESS_EPILOG = """\
────────────────────────────────────────────────────────────────────────────────
COMMON WORKFLOWS FOR LLM AGENTS:

  1. First run / smoke test (verify everything is set up):
     headless --verify

  2. Run a Windows .exe and capture a screenshot (the 80% case):
     headless init                                    # start virtual display
     headless exec /path/to/app.exe                   # returns {"session_id":"sess_...","arch":"x86_64"}
     headless wait-window sess_...                    # wait for window to appear and stabilize
     headless screenshot --session sess_... --out /tmp/capture.png
     headless kill sess_...                           # clean up

  3. Interact with the running app (click, type, key):
     headless click 400 300 --session sess_...        # left-click at (400,300)
     headless type "Hello World" --session sess_...   # type ASCII text
     headless key Return --session sess_...           # press Enter
     headless key Escape --session sess_...           # press Esc

  4. Accept EULA / OK dialogs that block the app:
     headless accept-dialog sess_...                  # press Enter on default button
     headless accept-dialog sess_... --clicks 3       # for multi-step wizards

  5. Inspect what's happening:
     headless list                                    # all sessions (running or dead)
     headless windows --session sess_...              # list windows + detect modals
     headless logs sess_... --lines 50                # Wine + EXE stdout/stderr (auto UTF-16 decode)

  6. Use the clipboard (for non-ASCII text input via Ctrl+V):
     headless clipboard --write "Tëxt wíth ünïcödé" --session sess_...
     headless key ctrl+v --session sess_...           # paste into app

NOTES:
  • ALL commands return a single JSON object to stdout. Parse it with json.loads().
  • Warnings and debug logs go to stderr (not stdout) — safe to parse stdout directly.
  • exe_path accepts both Unix paths (/home/z/app.exe) and Windows paths (C:\\\\windows\\\\system32\\\\notepad.exe).
  • The exec response includes "arch":"i386" or "arch":"x86_64" — use it to know which mode ran.
  • When multiple sessions are active, input commands (click/key/type/clipboard) require --session.
  • Session cache lives at ~/.cache/headlesslab/ (registry.json, debug.log, per-session dirs).
  • If headless --verify fails, the host is missing prerequisites — run ./bin/setup.sh --check.
────────────────────────────────────────────────────────────────────────────────"""

def main():
    parser = argparse.ArgumentParser(
        prog="headless",
        description=(
            "HeadlessLab — run Windows GUI apps headless on Linux (no sudo, no Docker, no GPU).\n"
            "Each command returns a single JSON object to stdout for easy parsing by LLM agents."
        ),
        epilog=HEADLESS_EPILOG,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )

    # Global flags
    parser.add_argument("--verify", action="store_true",
        help="Run the integrated smoke test (init → exec example → screenshot → analyze). Exit 0 on pass, 1 on fail.")

    subparsers = parser.add_subparsers(dest="command", metavar="command")

    # Command: init
    parser_init = subparsers.add_parser("init",
        help="Start Xvfb + Openbox (must run before exec)",
        description="Start the virtual Xvfb display and Openbox window manager. Must be run once before 'exec'. Returns the display number and geometry.",
        epilog='Example:\n  headless init\n  → {"status":"ok","display":":99","geometry":"1920x1080x24"}',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_init.add_argument("--geometry", default="1920x1080x24",
        help="Virtual display resolution (default: 1920x1080x24)")

    # Command: exec
    parser_exec = subparsers.add_parser("exec",
        help="Execute a Windows .exe (returns session_id)",
        description="Execute a Windows application (.exe) via Wine inside a bwrap sandbox. Returns a JSON object with session_id, pid, and arch (i386 or x86_64). Accepts both Unix paths (/home/z/app.exe) and Windows paths (C:\\\\windows\\\\system32\\\\notepad.exe).",
        epilog='Examples:\n  headless exec /path/to/app.exe\n  headless exec C:\\\\windows\\\\system32\\\\notepad.exe\n  → {"status":"ok","session_id":"sess_123","pid":987,"arch":"x86_64"}',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_exec.add_argument("exe_path", help="Path to the Windows .exe (Unix path or Windows C:\\\\... path)")
    parser_exec.add_argument("--display", help="X11 display to use (default: auto-detected from active sessions)")
    parser_exec.add_argument("--cwd", help="Custom working directory inside the sandbox (default: EXE's directory). Useful for apps that need a different cwd than the EXE's location.")
    parser_exec.add_argument("--wait", action="store_true",
        help="Block until a window appears or the process dies. Combines exec + wait-window in one call. Returns PROCESS_DIED if the app crashes, or {\"status\":\"ok\",\"window\":{...},\"elapsed_ms\":N} if a window stabilizes.")
    parser_exec.add_argument("--timeout", type=int, default=30000,
        help="Timeout in milliseconds for --wait (default: 30000). Only used when --wait is set.")
    parser_exec.add_argument("args", nargs=argparse.REMAINDER, help="Extra arguments to pass to the .exe")

    # Command: screenshot
    parser_screenshot = subparsers.add_parser("screenshot",
        help="Capture a PNG screenshot of the virtual display",
        description="Capture the root window (or a specific session's window) as a PNG. Tries ImageMagick 'import' first, falls back to python-xlib.",
        epilog='Examples:\n  headless screenshot --session sess_... --out /tmp/capture.png\n  headless screenshot --out /tmp/screen.png  (uses first active session)',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_screenshot.add_argument("--session", help="Session ID to capture (default: first active session)")
    parser_screenshot.add_argument("--out", help="Output PNG path (default: /tmp/screenshot_<timestamp>.png)")

    # Command: wait-window
    parser_wait = subparsers.add_parser("wait-window",
        help="Wait for window to appear and pixels to stabilize",
        description="Poll the session's window and wait until pixel output is stable for 150ms. Essential before taking screenshots — ensures the app has finished rendering.",
        epilog='Examples:\n  headless wait-window sess_...\n  headless wait-window sess_... --timeout 20000\n  → {"status":"ok","elapsed_ms":480}  (or {"status":"timeout"} with exit code 2)',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_wait.add_argument("session_id", help="Session ID")
    parser_wait.add_argument("--timeout", type=int, default=10000, help="Timeout in ms (default: 10000)")

    # Command: drag
    parser_drag = subparsers.add_parser("drag",
        help="Simulate a mouse drag from (x1,y1) to (x2,y2)",
        description="Simulate a mouse drag (mousedown → move → mouseup). Useful for sliders, drag-and-drop, and other UI interactions.",
        epilog='Example:\n  headless drag 100 200 500 200 --session sess_...\n  → {"status":"ok","from":{"x":100,"y":200},"to":{"x":500,"y":200}}',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_drag.add_argument("x1", type=int, help="Start X coordinate")
    parser_drag.add_argument("y1", type=int, help="Start Y coordinate")
    parser_drag.add_argument("x2", type=int, help="End X coordinate")
    parser_drag.add_argument("y2", type=int, help="End Y coordinate")
    parser_drag.add_argument("--session", help="Session ID (required if multiple sessions active)")
    parser_drag.add_argument("--display", help="X11 display (alternative to --session)")
    parser_drag.add_argument("--button", type=int, default=1, help="Mouse button (1=left, 2=middle, 3=right, default: 1)")
    parser_drag.add_argument("--duration", type=int, default=500, help="Drag duration in ms (default: 500)")

    # Command: scroll
    parser_scroll = subparsers.add_parser("scroll",
        help="Simulate mouse scroll wheel",
        description="Simulate a mouse scroll wheel event. Positive amount scrolls down, negative scrolls up.",
        epilog='Examples:\n  headless scroll 3 --session sess_...   (scroll down 3 clicks)\n  headless scroll -5 --session sess_...  (scroll up 5 clicks)',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_scroll.add_argument("amount", type=int, help="Scroll amount: positive=down, negative=up (max 100)")
    parser_scroll.add_argument("--session", help="Session ID (required if multiple sessions active)")
    parser_scroll.add_argument("--display", help="X11 display (alternative to --session)")

    # Command: type-unicode
    parser_type_u = subparsers.add_parser("type-unicode",
        help="Type Unicode text via clipboard + Ctrl+V",
        description="Type Unicode (non-ASCII) text by writing to clipboard and pasting with Ctrl+V. Use this for CJK, emoji, or any non-ASCII text.",
        epilog='Example:\n  headless type-unicode "日本語" --session sess_...\n  → {"status":"ok","text_length":3}',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_type_u.add_argument("text", help="Unicode text to type")
    parser_type_u.add_argument("--session", help="Session ID (required if multiple sessions active)")
    parser_type_u.add_argument("--display", help="X11 display (alternative to --session)")

    # Command: register-dll
    parser_register = subparsers.add_parser("register-dll",
        help="Register a DLL in the wineprefix template via regsvr32",
        description="Run regsvr32 on a DLL to register its COM classes in the template wineprefix. The registration persists across all future sessions. Supports both Unix paths (auto-converted) and Windows paths (C:\\\\...).",
        epilog='Examples:\n  headless register-dll /path/to/d3dx9_36.dll\n  headless register-dll C:\\\\windows\\\\syswow64\\\\dxdiagn.dll --arch i386\n  → {"status":"ok","dll":"...","arch":"i386","regsvr32":"C:\\\\windows\\\\syswow64\\\\regsvr32.exe"}',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_register.add_argument("dll_path", help="Path to the DLL (Unix path or Windows C:\\\\... path)")
    parser_register.add_argument("--arch", choices=["i386", "x86_64"],
        help="DLL architecture (default: auto-detect from PE header)")

    # Command: metrics
    parser_metrics = subparsers.add_parser("metrics",
        help="Return performance metrics for a session",
        description="Collect and return performance metrics: process CPU/memory, uptime, wine process count, screenshot capture latency, and unique color count. Useful for CI regression detection.",
        epilog='Example:\n  headless metrics sess_...\n  → {"status":"ok","pid":1234,"uptime_s":45,"process":{"cpu_time_s":1.2,"rss_mb":150.5,"alive":true,"wine_process_count":8},"screenshot":{"capture_ms":120.3,"unique_colors_sampled":50000}}',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_metrics.add_argument("session_id", help="Session ID")

    # Command: click
    parser_click = subparsers.add_parser("click",
        help="Simulate a mouse left-click at (x, y)",
        description="Simulate a mouse left-click at the given coordinates. Coordinates are relative to the virtual display (0,0 = top-left, 1919,1079 = bottom-right for 1920x1080).",
        epilog='Example:\n  headless click 400 300 --session sess_...\n  → {"status":"ok"}',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_click.add_argument("x", type=int, help="X coordinate (0-1919 for 1920x1080)")
    parser_click.add_argument("y", type=int, help="Y coordinate (0-1079 for 1920x1080)")
    parser_click.add_argument("--session", help="Session ID (required if multiple sessions active)")
    parser_click.add_argument("--display", help="X11 display (alternative to --session)")

    # Command: click-text
    parser_click_text = subparsers.add_parser("click-text",
        help="Find text on screen via OCR and click on it",
        description="Capture a screenshot, run OCR (tesseract) to find the target text, and click at the center of its bounding box. Falls back to 2x upscale and color-based button detection for low-contrast text.",
        epilog='Examples:\n  headless click-text "Training" --session sess_...\n  headless click-text "OK" --session sess_... --index 2\n  headless click-text "Cancel" --session sess_... --fuzzy\n  headless click-text "Save" --session sess_... --dry-run\n  → {"status":"ok","text":"Training","x":1219,"y":537,"width":280,"height":44,"confidence":93.5,"method":"ocr","clicked":true}',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_click_text.add_argument("text", help="Text to find and click (case-insensitive)")
    parser_click_text.add_argument("--session", help="Session ID (required if multiple sessions active)")
    parser_click_text.add_argument("--display", help="X11 display (alternative to --session)")
    parser_click_text.add_argument("--index", type=int, default=1,
        help="Which match to click if multiple (1-based, default: 1)")
    parser_click_text.add_argument("--fuzzy", action="store_true",
        help="Partial match: target is substring of detected text or vice versa")
    parser_click_text.add_argument("--dry-run", action="store_true",
        help="Find text and return coordinates without clicking")

    # Command: find-text
    parser_find_text = subparsers.add_parser("find-text",
        help="Find all occurrences of text on screen via OCR (no click)",
        description="Capture a screenshot, run OCR (tesseract) to find all occurrences of the target text, and return their bounding boxes. Uses the same 3-tier fallback as click-text: full-screen OCR, 2x upscale, color-based button detection. Does NOT click.",
        epilog='Examples:\n  headless find-text "Training" --session sess_...\n  headless find-text "OK" --session sess_... --fuzzy\n  → {"status":"ok","text":"Training","matches":[{"text":"Training","x":207,"y":232,...}],"count":1}',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_find_text.add_argument("text", help="Text to find (case-insensitive)")
    parser_find_text.add_argument("--session", help="Session ID (required if multiple sessions active)")
    parser_find_text.add_argument("--display", help="X11 display (alternative to --session)")
    parser_find_text.add_argument("--fuzzy", action="store_true",
        help="Partial match: target is substring of detected text or vice versa")

    # Command: find-buttons
    parser_find_buttons = subparsers.add_parser("find-buttons",
        help="Find all button-like regions on screen via color detection",
        description="Capture a screenshot, detect colored rectangular regions (buttons), and return each button's bounding box, dominant color, and OCR'd text. Does NOT click.",
        epilog='Example:\n  headless find-buttons --session sess_...\n  → {"status":"ok","buttons":[{"text":"Training","x":1219,"y":537,"width":280,"height":44,"button_color":[191,56,43]}],"count":1}',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_find_buttons.add_argument("--session", help="Session ID (required if multiple sessions active)")
    parser_find_buttons.add_argument("--display", help="X11 display (alternative to --session)")

    # Command: key
    parser_key = subparsers.add_parser("key",
        help="Press a key (KeySym name)",
        description="Press a single key using its X11 KeySym name. Common keys: Return, Escape, Tab, space, BackSpace, ctrl+c, ctrl+v, F1-F12, Up, Down, Left, Right.",
        epilog='Examples:\n  headless key Return --session sess_...\n  headless key ctrl+v --session sess_...  (paste from clipboard)',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_key.add_argument("keysym", help="KeySym name (e.g. Return, Escape, Tab, ctrl+v, ctrl+c)")
    parser_key.add_argument("--session", help="Session ID (required if multiple sessions active)")
    parser_key.add_argument("--display", help="X11 display (alternative to --session)")

    # Command: type
    parser_type = subparsers.add_parser("type",
        help="Type ASCII text (for Unicode, use clipboard + Ctrl+V)",
        description="Simulate typing ASCII text character by character. For non-ASCII (Unicode) text, use 'clipboard --write' followed by 'key ctrl+v' instead.",
        epilog='Example:\n  headless type "Hello World" --session sess_...',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_type.add_argument("text", help="ASCII text to type (non-ASCII will be rejected)")
    parser_type.add_argument("--session", help="Session ID (required if multiple sessions active)")
    parser_type.add_argument("--display", help="X11 display (alternative to --session)")

    # Command: clipboard
    parser_clip = subparsers.add_parser("clipboard",
        help="Read or write the X11 clipboard (for Unicode text input)",
        description="Read from or write to the X11 clipboard. Use '--write TEXT' to set the clipboard, then 'key ctrl+v' to paste into the app. Supports full Unicode (unlike 'type' which is ASCII-only).",
        epilog='Examples:\n  headless clipboard --write "Tëxt wíth ünïcödé" --session sess_...\n  headless clipboard --session sess_...  (read current clipboard)',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_clip.add_argument("--write", help="Write this text to the clipboard (omit to read instead)")
    parser_clip.add_argument("--session", help="Session ID (required if multiple sessions active)")
    parser_clip.add_argument("--display", help="X11 display (alternative to --session)")

    # Command: file-read
    parser_file_read = subparsers.add_parser("file-read",
        help="Read a file inside the Wine prefix (C:\\ drive)",
        description="Read a file from the Wine prefix's C:\\ drive. Accepts Windows paths (C:\\users\\...) or Unix paths. Auto-detects encoding (utf-8, utf-16, latin-1). Binary files are returned as base64.",
        epilog='Examples:\n  headless file-read C:\\\\users\\\\steamuser\\\\Documents\\\\save.dat --session sess_...\n  headless file-read "C:\\\\Program Files\\\\app\\\\config.ini" --session sess_...\n  → {"status":"ok","text":"file contents...","encoding":"utf-8","size":1234}',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_file_read.add_argument("path", help="Windows path (C:\\...) or Unix path to the file")
    parser_file_read.add_argument("--session", required=True, help="Session ID")

    # Command: file-write
    parser_file_write = subparsers.add_parser("file-write",
        help="Write text to a file inside the Wine prefix (C:\\ drive)",
        description="Write text to a file in the Wine prefix's C:\\ drive. Creates parent directories if needed. Accepts Windows paths (C:\\users\\...).",
        epilog='Example:\n  headless file-write C:\\\\users\\\\steamuser\\\\settings.ini --content "[Display]\\nWidth=1920" --session sess_...',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_file_write.add_argument("path", help="Windows path (C:\\...) for the file")
    parser_file_write.add_argument("--content", required=True, help="Text content to write")
    parser_file_write.add_argument("--session", required=True, help="Session ID")

    # Command: diff
    parser_diff = subparsers.add_parser("diff",
        help="Take 2 screenshots and compare — has the screen changed?",
        description="Capture two screenshots with an interval between them and compare pixels. Returns the percentage of pixels that changed. Useful for detecting whether the app is animating/loading or static/hung.",
        epilog='Examples:\n  headless diff --session sess_...                  (1s interval, default)\n  headless diff --session sess_... --interval 2     (2s interval)\n  headless diff --session sess_... --threshold 5    (5%% changed = "changed")\n  → {"status":"ok","changed":true,"diff_percent":15.3,"message":"Screen changed"}',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_diff.add_argument("--session", help="Session ID (required if multiple sessions active)")
    parser_diff.add_argument("--display", help="X11 display (alternative to --session)")
    parser_diff.add_argument("--interval", type=float, default=1.0, help="Seconds between captures (default: 1.0)")
    parser_diff.add_argument("--threshold", type=float, default=1.0, help="Percent of pixels that must differ to count as changed (default: 1.0)")

    # Command: wait-stable
    parser_wait_stable = subparsers.add_parser("wait-stable",
        help="Wait until the screen stops changing (loading finished)",
        description="Poll screenshots until consecutive frames are identical (within threshold). Returns when the screen has been stable for N consecutive frames. Useful for waiting until loading screens, transitions, or animations complete.",
        epilog='Examples:\n  headless wait-stable --session sess_...                          (default: 15s timeout, 3 stable frames)\n  headless wait-stable --session sess_... --timeout 30000          (30s timeout)\n  headless wait-stable --session sess_... --stable-frames 5        (need 5 identical frames)\n  → {"status":"ok","stable":true,"elapsed_ms":3200,"message":"Screen has stabilized"}',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_wait_stable.add_argument("--session", help="Session ID (required if multiple sessions active)")
    parser_wait_stable.add_argument("--display", help="X11 display (alternative to --session)")
    parser_wait_stable.add_argument("--timeout", type=int, default=15000, help="Timeout in ms (default: 15000)")
    parser_wait_stable.add_argument("--stable-frames", type=int, default=3, help="Consecutive identical frames needed (default: 3)")
    parser_wait_stable.add_argument("--poll-interval", type=float, default=0.5, help="Seconds between captures (default: 0.5)")
    parser_wait_stable.add_argument("--threshold", type=float, default=0.5, help="Percent of pixels that must differ to count as changed (default: 0.5)")

    # Command: windows
    parser_windows = subparsers.add_parser("windows",
        help="List all open windows (detects modals)",
        description="List all mapped windows on the virtual display, grouped by session. Each window entry includes id, pid, session_id, title, and type ('normal' or 'modal'). Use this to find window titles or detect blocking dialogs.",
        epilog='Example:\n  headless windows --session sess_...\n  → {"status":"ok","windows":[{"id":"0x00c00001","pid":1234,"session_id":"sess_...","title":"My App","type":"normal"}]}',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_windows.add_argument("--session", help="Filter windows by session ID")
    parser_windows.add_argument("--display", help="X11 display (alternative to --session)")

    # Command: focus
    parser_focus = subparsers.add_parser("focus",
        help="Focus a session's window",
        description="Activate (focus) the main window of a session. Useful before sending input to ensure the right window receives it.",
        epilog='Example:\n  headless focus sess_...',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_focus.add_argument("session_id", help="Session ID")

    # Command: accept-dialog
    parser_accept = subparsers.add_parser("accept-dialog",
        help="Auto-accept a modal dialog (EULA, OK/Cancel) by pressing Enter",
        description="Focus the most recent window (usually a modal dialog) and press Enter to activate the default button (OK, Accept, Yes, etc.). For multi-step wizards, use --clicks N.",
        epilog='Examples:\n  headless accept-dialog sess_...                  (press Enter once)\n  headless accept-dialog sess_... --clicks 3       (for 3-step wizard)\n  → {"status":"ok","pressed_enter_count":1,"window_id":"0x...","window_title":"License Agreement"}',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_accept.add_argument("session_id", help="Session ID")
    parser_accept.add_argument("--clicks", type=int, default=1,
        help="Number of Enter presses (default 1). Use >1 for multi-step wizards.")
    parser_accept.add_argument("--delay", type=float, default=0.3,
        help="Delay between Enter presses in seconds (default 0.3)")

    # Command: logs
    parser_logs = subparsers.add_parser("logs",
        help="Get Wine + EXE stdout/stderr logs (auto UTF-16 decode)",
        description="Return the log output (stdout + stderr) of a session. Includes Wine debug messages AND the EXE's own printf output. Auto-decodes UTF-16 output (common for Windows console apps like sigcheck, ipconfig).",
        epilog='Examples:\n  headless logs sess_...                           (full log)\n  headless logs sess_... --lines 50                (last 50 lines)\n  → {"status":"ok","logs":"=== DX9 Test Program ===\\n[OK] Window created..."}',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_logs.add_argument("session_id", help="Session ID")
    parser_logs.add_argument("--lines", type=int, help="Number of lines from the tail (default: all)")

    # Command: kill
    parser_kill = subparsers.add_parser("kill",
        help="Kill a session and free resources",
        description="Kill all Wine processes belonging to a session (by WINEPREFIX), then delete the session cache directory. Returns the list of killed PIDs.",
        epilog='Example:\n  headless kill sess_...\n  → {"status":"ok","killed_pids":[1234,1235,1236,...]}',
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser_kill.add_argument("session_id", help="Session ID")

    # Command: list
    parser_list = subparsers.add_parser("list",
        help="List all sessions (running and dead)",
        description="List all registered sessions. Dead sessions (where the PID no longer exists) are preserved with state='dead' so you can still inspect their logs via 'logs <session_id>'.",
        epilog='Example:\n  headless list\n  → {"status":"ok","sessions":[{"session_id":"sess_...","pid":1234,"state":"running",...}]}',
        formatter_class=argparse.RawDescriptionHelpFormatter)

    args = parser.parse_args()

    if args.verify:
        run_verify(args)
        return

    if not args.command:
        parser.print_help()
        sys.exit(0)

    # Command Router
    command_map = {
        "init": cmd_init,
        "exec": cmd_exec,
        "screenshot": cmd_screenshot,
        "click": cmd_click,
        "click-text": cmd_click_text,
        "find-text": cmd_find_text,
        "find-buttons": cmd_find_buttons,
        "key": cmd_key,
        "type": cmd_type,
        "type-unicode": cmd_type_unicode,
        "drag": cmd_drag,
        "scroll": cmd_scroll,
        "logs": cmd_logs,
        "kill": cmd_kill,
        "list": cmd_list,
        "clipboard": cmd_clipboard,
        "windows": cmd_windows,
        "focus": cmd_focus,
        "accept-dialog": cmd_accept_dialog,
        "wait-window": cmd_wait_window,
        "wait-stable": cmd_wait_stable,
        "register-dll": cmd_register_dll,
        "metrics": cmd_metrics,
        "file-read": cmd_file_read,
        "file-write": cmd_file_write,
        "diff": cmd_diff
    }

    try:
        command_map[args.command](args)
    except Exception as e:
        print_error("UNCAUGHT_EXCEPTION", str(e), exit_code=99)

if __name__ == "__main__":
    main()
